generator client {
  provider = "prisma-client-js"
  // Generate into the source tree so Vercel never serves a stale @prisma/client
  // from a cached node_modules between deploys. (Default node_modules/.prisma/
  // path was being cached across deploys, missing newly-added models.)
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  TRAINER
  CLIENT
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum ShareType {
  READ_ONLY
  CO_MANAGE
  TRANSFER
}

enum SessionType {
  IN_PERSON
  VIRTUAL
}

enum SessionStatus {
  UPCOMING
  COMPLETED
  COMMENTED
  INVOICED
}

enum MessageChannel {
  TRAINER_CLIENT // visible to client
  TRAINER_TRAINER // private between trainers
}

enum CustomFieldType {
  TEXT
  NUMBER
  DROPDOWN
}

enum ProductKind {
  PHYSICAL
  DIGITAL
}

enum ProductRequestStatus {
  PENDING // client wants this, hasn't been delivered yet
  FULFILLED // trainer marked it delivered (linked to a session)
  CANCELLED // client withdrew the request, or trainer dismissed it
}

// ─── Core User ───────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  // Defaults to TRAINER so PrismaAdapter can create rows for OAuth (Apple/Google)
  // sign-ins which don't supply a role. Existing flows (Credentials sign-up,
  // invite acceptance) set role explicitly and override the default.
  role          Role      @default(TRAINER)
  emailVerified DateTime?
  image         String?
  timezone      String    @default("Pacific/Auckland")

  notifyEmail Boolean @default(true)
  notifyPush  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth
  accounts Account[]
  sessions Session[]

  // Role-specific profiles
  trainerProfile TrainerProfile?
  clientProfile  ClientProfile?

  // Messages sent by this user
  sentMessages Message[]

  // Push notification device tokens (one user can have multiple devices)
  deviceTokens DeviceToken[]

  // Per-(type, channel) preferences. Absence of a row means "use the default".
  notificationPreferences NotificationPreference[]

  @@map("users")
}

enum DevicePlatform {
  IOS
  ANDROID
}

// What kind of event a notification is for. Add new variants as we wire up
// more triggers — the preference matrix UI renders one row per type.
enum NotificationType {
  SESSION_REMINDER // n minutes before a TrainingSession starts
  SESSION_NOTES_REMINDER // n minutes before a TrainingSession ends — prompts the trainer to write session notes
  NEW_CLIENT_INVITE_ACCEPTED // a client used the invite link to sign up
  CLIENT_COMPLETED_TASKS // a client completed all of today's tasks
  NEW_MESSAGE // a new in-app message landed
  DAILY_SUMMARY // morning digest of today's sessions/tasks
}

enum NotificationChannel {
  PUSH
  EMAIL
}

// Per-(user, type, channel) preference. Absence of a row means "use the
// type's default" (typically enabled). `minutesBefore` is only meaningful for
// time-relative types like SESSION_REMINDER; null otherwise.
model NotificationPreference {
  id            String              @id @default(cuid())
  userId        String
  type          NotificationType
  channel       NotificationChannel
  enabled       Boolean             @default(true)
  // Time-relative (e.g. SESSION_REMINDER) — minutes before the event fires.
  minutesBefore Int?
  // Time-of-day (e.g. DAILY_SUMMARY) — hour 0–23 in the user's timezone.
  dailyAtHour   Int?
  // Optional per-user copy overrides. Support {{placeholders}} that the
  // sender substitutes (e.g. {{dogName}}, {{startTime}}, {{count}}). Null
  // values fall back to the type's default template.
  customTitle   String?
  customBody    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId])
  @@map("notification_preferences")
}

model DeviceToken {
  id         String         @id @default(cuid())
  userId     String
  token      String         @unique
  platform   DevicePlatform
  createdAt  DateTime       @default(now())
  lastSeenAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ─── NextAuth Models ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Trainer Profile ─────────────────────────────────────────────────────────

model TrainerProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  businessName     String
  phone            String?
  logoUrl          String?
  dashboardBgUrl   String? // background image shown on the client home dashboard
  inviteTemplate   String? @db.Text // customisable invite email template
  // Hex colour for the accent strip across the top of outbound emails.
  // Falls back to a violet default when null.
  emailAccentColor String?

  // Google Calendar integration
  googleCalendarRefreshToken String? @db.Text
  googleCalendarConnected    Boolean @default(false)

  // Schedule view preferences — controls the visible hour range and which
  // weekdays render in the week grid. Days are 1=Mon..7=Sun.
  scheduleStartHour   Int     @default(7) // inclusive
  scheduleEndHour     Int     @default(21) // exclusive (last hour shown is end-1)
  scheduleDays        Json    @default("[1,2,3,4,5,6,7]")
  // Up to 2 extra fields rendered on schedule blocks. Allowed ids:
  // "location" | "description" | "sessionType" | "duration" | "title"
  scheduleExtraFields Json    @default("[]")
  // Ordered list of intake-form section names (string[]). Lets trainers create
  // empty sections and drag fields into them; without this, a section only
  // "existed" if at least one field had that category. Fields whose category
  // doesn't appear in this list pile into a "Fields without a section" bucket.
  intakeSectionOrder  Json    @default("[]")
  // Whether the intake form is published (visible to clients). Defaults to
  // false so newly-seeded intake fields don't go live until the trainer
  // explicitly publishes from the intake editor.
  intakeFormPublished Boolean @default(false)
  // Trainer-chosen visible columns on /clients. Allowed ids:
  // "email" | "dog" | "breed" | "extraDogs" | "nextSession" | "compliance" | "shared" | "custom:<id>"
  clientListColumns   Json    @default("[\"email\",\"dog\",\"nextSession\",\"compliance\"]")
  // Grouping for /clients. null = flat list. "nextDay" = group by day of
  // next booking. "custom:<id>" = group by custom-field value.
  clientListGroupBy   String?

  // Subscription
  subscriptionPlanId String?
  subscriptionStatus SubscriptionStatus @default(TRIALING)
  // When the free trial expires. Stamped on signup (now + 14 days). Null
  // for paid plans that don't have a trial window or trainers who never
  // had one (legacy accounts).
  trialEndsAt        DateTime?
  // Stripe identifiers — populated lazily, the first time the trainer
  // hits Checkout. Customer is reused across plan changes; subscription
  // and price flip when they upgrade/downgrade.
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  // End of the current paid period — drives the "renews on …" copy and
  // the access-cutoff job for cancelled subscriptions.
  currentPeriodEnd     DateTime?
  // Number of trainer seats the subscription was booked for. Mirrors
  // the Stripe subscription's quantity. 1 by default; bumps via the
  // slider on /billing/setup.
  seatCount            Int       @default(1)
  // Business postal address — captured on /billing/setup, used for
  // Stripe customer billing details, invoice rendering, and tax-region
  // reporting. All optional so existing trainers don't get blocked.
  addressLine1         String?
  addressLine2         String?
  addressCity          String?
  addressRegion        String?
  addressPostcode      String?
  addressCountry       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan   SubscriptionPlan?          @relation(fields: [subscriptionPlanId], references: [id])
  clients            ClientProfile[]
  sharedClients      ClientShare[]              @relation("SharedByTrainer")
  receivedClients    ClientShare[]              @relation("SharedWithTrainer")
  trainingSessions   TrainingSession[]
  trainingTemplates  TrainingTemplate[]
  customFields       CustomField[]
  libraryTypes       LibraryType[]
  embedForms         EmbedForm[]
  enquiries          Enquiry[]
  sentNotifications  ClientNotification[]
  availabilitySlots  AvailabilitySlot[]
  blackoutPeriods    BlackoutPeriod[]
  packages           Package[]
  sessionForms       SessionForm[]
  products           Product[]
  achievements       Achievement[]
  onboardingProgress TrainerOnboardingProgress?

  @@map("trainer_profiles")
}

// ─── Client & Dog ────────────────────────────────────────────────────────────

model ClientProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  trainerId String // primary trainer
  dogId     String? // set after onboarding
  status    String  @default("ACTIVE") // "ACTIVE" | "INACTIVE"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainer TrainerProfile @relation(fields: [trainerId], references: [id])
  dog     Dog?           @relation("PrimaryDog", fields: [dogId], references: [id])

  diaryEntries      TrainingTask[]
  trainingSessions  TrainingSession[]
  shares            ClientShare[]
  messages          Message[]            @relation("ClientMessages")
  customFieldValues CustomFieldValue[]
  dogs              Dog[]                @relation("AdditionalDogs")
  notifications     ClientNotification[]
  clientPackages    ClientPackage[]
  productRequests   ProductRequest[]
  buddySessions     SessionBuddy[]
  achievements      ClientAchievement[]
  enquiry           Enquiry?

  @@index([trainerId])
  @@map("client_profiles")
}

model Dog {
  id              String    @id @default(cuid())
  name            String
  breed           String?
  weight          Float? // kg
  dob             DateTime?
  photoUrl        String?
  notes           String?   @db.Text
  clientProfileId String? // owner (for additional dogs in a household)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  primaryFor    ClientProfile[]   @relation("PrimaryDog")
  owner         ClientProfile?    @relation("AdditionalDogs", fields: [clientProfileId], references: [id])
  sessions      TrainingSession[]
  tasks         TrainingTask[]
  buddySessions SessionBuddy[]

  @@index([clientProfileId])
  @@map("dogs")
}

// ─── Client Sharing ───────────────────────────────────────────────────────────

model ClientShare {
  id           String    @id @default(cuid())
  clientId     String
  sharedById   String
  sharedWithId String
  shareType    ShareType
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())

  client     ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sharedBy   TrainerProfile @relation("SharedByTrainer", fields: [sharedById], references: [id])
  sharedWith TrainerProfile @relation("SharedWithTrainer", fields: [sharedWithId], references: [id])

  @@index([clientId])
  @@index([sharedWithId])
  @@map("client_shares")
}

// ─── Training Diary & Tasks ───────────────────────────────────────────────────

model TrainingTask {
  id          String   @id @default(cuid())
  clientId    String
  dogId       String? // optional: which dog this task is for
  sessionId   String? // optional: linked training session
  date        DateTime @db.Date
  title       String
  description String?  @db.Text
  repetitions Int?
  videoUrl    String? // trainer-provided instructional link
  trainerNote String?  @db.Text // per-task comment from the trainer
  imageUrls   Json     @default("[]") // string[] of public image URLs
  order       Int      @default(0) // display order within a session

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     ClientProfile    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dog        Dog?             @relation(fields: [dogId], references: [id])
  session    TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  completion TaskCompletion?

  @@index([clientId])
  @@index([date])
  @@index([sessionId])
  @@map("training_tasks")
}

model TaskCompletion {
  id          String   @id @default(cuid())
  taskId      String   @unique
  completedAt DateTime @default(now())
  note        String?  @db.Text
  videoUrl    String? // client-submitted link
  videoS3Key  String? // native video upload (S3)

  task TrainingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_completions")
}

// ─── Scheduling ──────────────────────────────────────────────────────────────

model TrainingSession {
  id              String        @id @default(cuid())
  trainerId       String
  clientId        String? // direct client link (optional, in addition to dogId)
  dogId           String?
  clientPackageId String? // membership in an assigned package
  title           String
  description     String?       @db.Text
  scheduledAt     DateTime
  durationMins    Int           @default(60)
  sessionType     SessionType   @default(IN_PERSON)
  status          SessionStatus @default(UPCOMING)
  // Whether the trainer has invoiced this session (Xero/QBO/manual). Tracked
  // separately from `status` because invoicing can happen before OR after the
  // session is marked complete — the lifecycles are orthogonal. Null = not
  // invoiced; set = invoiced at this timestamp.
  invoicedAt      DateTime?
  location        String?
  virtualLink     String?

  googleCalendarEventId String?

  // Set when the "starting in ~20 min" push reminder has been delivered to the
  // trainer, so the cron loop never sends two pushes for the same session.
  reminderPushSentAt      DateTime?
  // Same idea for the "ends in ~5 min — write session notes" reminder.
  notesReminderPushSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer                  TrainerProfile        @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  client                   ClientProfile?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  dog                      Dog?                  @relation(fields: [dogId], references: [id])
  clientPackage            ClientPackage?        @relation(fields: [clientPackageId], references: [id], onDelete: SetNull)
  tasks                    TrainingTask[]
  formResponses            SessionFormResponse[]
  fulfilledProductRequests ProductRequest[]
  buddies                  SessionBuddy[]

  @@index([trainerId])
  @@index([clientId])
  @@index([scheduledAt])
  @@index([clientPackageId])
  @@map("training_sessions")
}

// "Buddy session" — additional client/dog pairs attending a TrainingSession
// alongside the primary client/dog. Trainer-only visibility (the buddy client's
// portal does not surface these). Same client may appear twice with two
// different dogs, so the unique key includes dogId.
model SessionBuddy {
  id        String   @id @default(cuid())
  sessionId String
  clientId  String
  dogId     String?
  createdAt DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  client  ClientProfile   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dog     Dog?            @relation(fields: [dogId], references: [id], onDelete: SetNull)

  @@unique([sessionId, clientId, dogId])
  @@index([sessionId])
  @@index([clientId])
  @@map("session_buddies")
}

// ─── Products (trainer shop) ─────────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  trainerId   String
  name        String
  description String?     @db.Text
  kind        ProductKind @default(PHYSICAL)
  // Price in cents to avoid float issues. Null = unpriced / "Contact trainer".
  priceCents  Int?
  imageUrl    String?
  // Required for DIGITAL products — the file the customer downloads. Public URL
  // (e.g. Vercel Blob) or signed URL handed out at access time.
  downloadUrl String?
  category    String? // free-form trainer-defined grouping ("Treats", "Guides")
  featured    Boolean     @default(false) // surfaces on the client home dashboard
  active      Boolean     @default(true) // hide from clients without deleting
  order       Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer  TrainerProfile   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  requests ProductRequest[]

  @@index([trainerId])
  @@index([category])
  @@map("products")
}

// A client's standing request for a product. Stays PENDING and rolls forward
// onto each successive upcoming session until the trainer marks it FULFILLED
// (typically because they handed the item over at a session) or CANCELLED.
model ProductRequest {
  id        String               @id @default(cuid())
  clientId  String
  productId String
  status    ProductRequestStatus @default(PENDING)

  // Optional notes from the client when they request (e.g. "for Bella, size L")
  note String? @db.Text

  // Set when trainer fulfils the request — links it to the session where it
  // was delivered, for the trainer's own records.
  fulfilledSessionId String?
  fulfilledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client           ClientProfile    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  fulfilledSession TrainingSession? @relation(fields: [fulfilledSessionId], references: [id], onDelete: SetNull)

  @@index([clientId, status])
  @@index([productId])
  @@map("product_requests")
}

// ─── Packages ─────────────────────────────────────────────────────────────────

model Package {
  id                   String      @id @default(cuid())
  trainerId            String
  name                 String
  description          String?     @db.Text
  sessionCount         Int         @default(3)
  weeksBetween         Int         @default(2) // gap between sessions, in weeks
  durationMins         Int         @default(60) // default duration applied to created sessions
  sessionType          SessionType @default(IN_PERSON)
  // Prices in cents to avoid float precision issues. specialPriceCents is an
  // optional discounted price the trainer can offer for promotions, etc.
  priceCents           Int? // null = unpriced
  specialPriceCents    Int? // null = no special price
  // Optional schedule colour (Tailwind palette key, eg "blue"). When set,
  // sessions assigned to this package render in that colour on the calendar.
  color                String?
  order                Int         @default(0) // display order, lowest first
  // Optional default session form. When a session is opened with this package
  // and no form responses exist, the default form is auto-attached.
  defaultSessionFormId String?
  // When false, suppress the SESSION_NOTES_REMINDER push for sessions in this
  // package. Some packages (e.g. drop-in classes) don't need a follow-up.
  // Defaults to true so existing packages keep firing reminders.
  requireSessionNotes  Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer            TrainerProfile  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  assignments        ClientPackage[]
  defaultSessionForm SessionForm?    @relation("PackageDefaultSessionForm", fields: [defaultSessionFormId], references: [id], onDelete: SetNull)

  @@index([trainerId])
  @@index([defaultSessionFormId])
  @@map("packages")
}

model ClientPackage {
  id                 String   @id @default(cuid())
  packageId          String
  clientId           String
  startDate          DateTime
  assignedAt         DateTime @default(now())
  // When true, the schedule auto-creates more sessions on the package's
  // cadence so the calendar always has ~6 weeks of sessions ahead.
  extendIndefinitely Boolean  @default(false)
  // Manual flag the trainer ticks when they've sent the invoice for this
  // assignment outside PupManager (Xero/QBO/cash). Null = not invoiced yet.
  // Once we wire real billing this is what the financial layer keys off.
  invoicedAt         DateTime?

  package  Package           @relation(fields: [packageId], references: [id], onDelete: Cascade)
  client   ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessions TrainingSession[]

  @@index([clientId])
  @@index([packageId])
  @@map("client_packages")
}

// ─── Session report forms ─────────────────────────────────────────────────────

// Trainer-defined questionnaire that can be attached to any TrainingSession to
// capture a structured report. Questions live as a JSON array so the trainer
// can reorder/add/remove without schema migrations:
//   [{ id, label, type: 'SHORT_TEXT'|'LONG_TEXT'|'NUMBER'|'RATING_1_5', required }]
model SessionForm {
  id              String  @id @default(cuid())
  trainerId       String
  name            String
  description     String? @db.Text
  introText       String? @db.Text // shown above the questions during fill + on the report
  closingText     String? @db.Text // shown below the questions during fill + on the report
  // Visual treatment for the client-facing report. backgroundUrl wins over
  // backgroundColor when both are set.
  backgroundColor String? // hex/CSS colour, e.g. "#fef3c7"
  backgroundUrl   String? // public image URL, applied as a tiled cover
  questions       Json    @default("[]")
  order           Int     @default(0)
  // When false the form is a draft — hidden from the trainer's session-form
  // picker. New defaults seeded by the onboarding init helper start as drafts
  // so trainers review them before they're usable in real sessions.
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer            TrainerProfile        @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  responses          SessionFormResponse[]
  defaultForPackages Package[]             @relation("PackageDefaultSessionForm")

  @@index([trainerId])
  @@map("session_forms")
}

// One trainer-filled response per (session, form). A session can have many
// responses (multiple forms attached). `answers` is a JSON object keyed by
// question id → string (we store everything as text; rendering interprets it).
model SessionFormResponse {
  id               String  @id @default(cuid())
  sessionId        String
  formId           String
  answers          Json    @default("{}")
  // Per-question image lists, keyed by question id → string[] of URLs
  imagesByQuestion Json    @default("{}")
  // Trainer-authored top/bottom messages for the report. Optional and
  // independent of the form template's introText/closingText (which act as
  // suggested defaults the trainer can copy in).
  introMessage     String? @db.Text
  closingMessage   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  form    SessionForm     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([sessionId, formId])
  @@index([sessionId])
  @@index([formId])
  @@map("session_form_responses")
}

// ─── Training Templates ───────────────────────────────────────────────────────

model TrainingTemplate {
  id          String  @id @default(cuid())
  trainerId   String
  name        String
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  tasks   TemplateTask[]

  @@map("training_templates")
}

model TemplateTask {
  id          String  @id @default(cuid())
  templateId  String
  dayOffset   Int // day 1, 2, 3... from program start
  title       String
  description String? @db.Text
  repetitions Int?
  videoUrl    String?
  order       Int     @default(0)

  template TrainingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_tasks")
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model Message {
  id       String         @id @default(cuid())
  channel  MessageChannel
  clientId String // the client this message thread relates to
  senderId String
  body     String         @db.Text
  readAt   DateTime?

  createdAt DateTime @default(now())

  client ClientProfile @relation("ClientMessages", fields: [clientId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id])

  @@index([clientId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("notifications")
}

// ─── Custom Client Fields ─────────────────────────────────────────────────────

model CustomField {
  id        String          @id @default(cuid())
  trainerId String
  label     String
  type      CustomFieldType
  required  Boolean         @default(false)
  options   Json? // string[] for DROPDOWN
  order     Int             @default(0)
  category  String? // optional grouping label
  appliesTo String          @default("OWNER") // "OWNER" | "DOG"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile     @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  values  CustomFieldValue[]

  @@index([trainerId])
  @@map("custom_fields")
}

model CustomFieldValue {
  id       String  @id @default(cuid())
  fieldId  String
  clientId String
  dogId    String? // set when field appliesTo = "DOG"
  value    String  @db.Text

  updatedAt DateTime @updatedAt

  field  CustomField   @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  client ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([fieldId, clientId, dogId])
  @@map("custom_field_values")
}

// ─── Subscription Plans ───────────────────────────────────────────────────────

model SubscriptionPlan {
  id           String  @id @default(cuid())
  name         String
  description  String? @db.Text
  priceMonthly Float
  maxClients   Int? // null = unlimited
  featureFlags Json    @default("{}")
  isActive     Boolean @default(true)
  // Stripe Price ID this plan maps to (e.g. price_1Abc…). Null while a
  // plan exists in our DB but hasn't been wired to Stripe yet — the
  // checkout flow filters those out so the trainer can't pick a plan
  // we can't actually charge for.
  stripePriceId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainers TrainerProfile[]

  @@map("subscription_plans")
}

// ─── Training Library ─────────────────────────────────────────────────────────

model LibraryType {
  id        String   @id @default(cuid())
  trainerId String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  themes  LibraryTheme[]

  @@index([trainerId])
  @@map("library_types")
}

model LibraryTheme {
  id        String   @id @default(cuid())
  typeId    String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type  LibraryType   @relation(fields: [typeId], references: [id], onDelete: Cascade)
  tasks LibraryTask[]

  @@index([typeId])
  @@map("library_themes")
}

model LibraryTask {
  id          String   @id @default(cuid())
  themeId     String
  title       String
  description String?  @db.Text
  repetitions Int?
  videoUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  theme LibraryTheme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@index([themeId])
  @@map("library_tasks")
}

// ─── Client Notifications ─────────────────────────────────────────────────────

model ClientNotification {
  id        String   @id @default(cuid())
  clientId  String
  trainerId String
  subject   String
  notes     String?  @db.Text
  sentAt    DateTime @default(now())

  client  ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_notifications")
}

// ─── Trainer Availability ─────────────────────────────────────────────────────

model AvailabilitySlot {
  id           String    @id @default(cuid())
  trainerId    String
  title        String?
  dayOfWeek    Int? // 1=Mon … 7=Sun; null = one-off date
  date         DateTime? @db.Date
  startTime    String // "HH:MM" 24-hr
  endTime      String // "HH:MM" 24-hr
  // 1 = weekly, 2 = fortnightly, etc. Only used when dayOfWeek is set.
  cadenceWeeks Int       @default(1)
  // Anchor date for cadence > 1 — defines parity (e.g. which fortnight is "on").
  firstDate    DateTime? @db.Date
  createdAt    DateTime  @default(now())

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@map("availability_slots")
}

// Trainer holiday / blackout periods. Days that fall inside one of these
// ranges count as unavailable, regardless of weekly slots.
model BlackoutPeriod {
  id        String   @id @default(cuid())
  trainerId String
  reason    String?
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@map("blackout_periods")
}

// ─── Trainer-defined Achievements ────────────────────────────────────────────

enum AchievementTrigger {
  MANUAL
  FIRST_SESSION
  SESSIONS_COMPLETED
  IN_PERSON_SESSIONS
  VIRTUAL_SESSIONS
  CONSECUTIVE_SESSIONS_ATTENDED
  FIRST_PACKAGE_ASSIGNED
  PACKAGES_COMPLETED
  FIRST_HOMEWORK_DONE
  HOMEWORK_TASKS_DONE
  HOMEWORK_STREAK_DAYS
  PERFECT_WEEK
  CLIENT_ANNIVERSARY_DAYS
  MESSAGES_SENT
  PRODUCTS_PURCHASED
  PROFILE_COMPLETED
}

// Trainer-curated catalogue of achievements / badges. Each row is *either* a
// MANUAL achievement (trainer awards from the client profile) *or* an automatic
// rule with a trigger type and threshold (system awards via evaluateAchievementsFor).
model Achievement {
  id           String             @id @default(cuid())
  trainerId    String
  name         String
  description  String?            @db.Text
  icon         String?
  color        String?
  order        Int                @default(0)
  // When false the achievement is hidden from clients and not auto-awarded.
  // Trainers use this to draft new achievements before surfacing them or to
  // pause an existing one without deleting it.
  published    Boolean            @default(true)
  // Auto-award rule. MANUAL = no auto-award; the rest are evaluated by the
  // awarder helper when relevant counters change. triggerValue is the integer
  // threshold (eg 5 for "5 sessions"); null for binary triggers.
  triggerType  AchievementTrigger @default(MANUAL)
  triggerValue Int?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  trainer TrainerProfile      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  awards  ClientAchievement[]

  @@index([trainerId])
  @@map("achievements")
}

// Per-client award log. Unique on (clientId, achievementId) so the awarder is
// idempotent — re-evaluating a client never double-awards. earnedValue captures
// the snapshot counter at award time so the UI can render "5 sessions".
model ClientAchievement {
  id            String   @id @default(cuid())
  clientId      String
  achievementId String
  awardedAt     DateTime @default(now())
  // "system" for automatic awards, the trainer's userId for manual awards.
  awardedBy     String
  earnedValue   Int?

  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  achievement Achievement   @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([clientId, achievementId])
  @@index([clientId])
  @@map("client_achievements")
}

// ─── Embed Forms ──────────────────────────────────────────────────────────────

model EmbedForm {
  id              String   @id @default(cuid())
  trainerId       String
  title           String
  description     String?  @db.Text
  // JSON array of { key: string, required: boolean } for standard fields
  // Keys: phone | dogName | dogBreed | dogWeight | dogDob | message
  fields          Json     @default("[]")
  // JSON string[] of CustomField ids to include
  customFieldIds  Json     @default("[]")
  thankYouTitle   String?  @db.Text
  thankYouMessage String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  enquiries Enquiry[]

  @@index([trainerId])
  @@map("embed_forms")
}

// ─── Enquiries (lead funnel) ──────────────────────────────────────────────────
// Form submissions land here in NEW state. Trainer can Reply, then Accept
// (creates User + ClientProfile + Dog + magic-link email) or Decline.
// Form values are snapshotted as columns + JSON so an enquiry stays readable
// even if the embed form's field config changes later.

model Enquiry {
  id        String  @id @default(cuid())
  trainerId String
  formId    String? // null if the source form was deleted

  // Snapshot of form values at submit time
  name              String
  email             String
  phone             String?
  dogName           String?
  dogBreed          String?
  dogWeight         Float?
  dogDob            DateTime?
  message           String?   @db.Text
  // { customFieldId: value } map of custom-field answers, snapshotted
  customFieldValues Json      @default("{}")

  status          EnquiryStatus @default(NEW)
  // Set when the trainer first opens the enquiry — drives the dashboard badge.
  viewedAt        DateTime?
  // Populated after Accept; gives a forward link to the resulting client.
  clientProfileId String?       @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer       TrainerProfile   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  form          EmbedForm?       @relation(fields: [formId], references: [id], onDelete: SetNull)
  clientProfile ClientProfile?   @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  messages      EnquiryMessage[]

  @@index([trainerId, status])
  @@index([trainerId, createdAt])
  @@map("enquiries")
}

enum EnquiryStatus {
  NEW
  ACCEPTED
  DECLINED
  ARCHIVED
}

// Outbound replies the trainer sent to the enquirer. v1 is one-way (no
// inbound threading) so direction is implicit-outbound; we still keep the
// column to make v2 (Gmail/Microsoft OAuth, two-way) a non-breaking change.
model EnquiryMessage {
  id           String   @id @default(cuid())
  enquiryId    String
  direction    String   @default("OUTBOUND") // "OUTBOUND" | "INBOUND"
  subject      String
  bodyText     String   @db.Text
  // Trainer (User) who composed and sent this. Null if system-generated.
  sentByUserId String?
  createdAt    DateTime @default(now())

  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  @@index([enquiryId, createdAt])
  @@map("enquiry_messages")
}

// ─── Onboarding ──────────────────────────────────────────────────────────────

// Admin-editable wizard step content. The trainer-facing wizard reads
// `publishedAt IS NOT NULL` rows ordered by `order`. Per-trainer state lives
// in TrainerOnboardingStepProgress, joined by `key` (no FK so admins can
// rename keys without cascading through trainer history).
model OnboardingStep {
  id          String    @id @default(cuid())
  key         String    @unique
  order       Int       @default(0)
  title       String
  body        String    @db.Text
  ctaLabel    String
  ctaHref     String
  skippable   Boolean   @default(true)
  skipWarning String?   @db.Text
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_steps")
}

// Admin-editable email template + send rule. The cron sender evaluates each
// published row's triggerRule against trainer state and dispatches via Resend.
// `senderKey` selects the founder voice ("karl" | "brooke") for from-address
// and signature.
model OnboardingEmail {
  id          String    @id @default(cuid())
  key         String    @unique
  subject     String
  body        String    @db.Text
  senderKey   String    @default("karl")
  // Examples:
  //   { "type": "on_signup" }
  //   { "type": "after_signup", "hours": 24, "requireStepIncomplete": "business_profile" }
  //   { "type": "after_first_invite_sent", "hours": 24, "requireNoClientSignedIn": true }
  //   { "type": "on_aha_reached" }
  triggerRule Json
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_emails")
}

// One row per trainer, created on first dashboard load. ahaReachedAt fires
// when this trainer's first non-sample client signs in for the first time.
model TrainerOnboardingProgress {
  id                   String    @id @default(cuid())
  trainerId            String    @unique
  startedAt            DateTime  @default(now())
  ahaReachedAt         DateTime?
  // Timestamp of the trainer's first sent client invite — anchors the
  // chase-sequence drips (emails 3 and 4).
  firstInviteSentAt    DateTime?
  // Trainer dismissed the dashboard checklist widget independently of completion.
  checklistDismissedAt DateTime?
  // Set on the row when it was created via post-deploy backfill (trainer
  // existed before onboarding shipped). Suppresses auto-modal — instead the
  // dashboard shows a one-time opt-in banner. Null = fresh signup.
  backfilledAt         DateTime?
  // Set when the trainer dismissed the first-visit welcome modal — either by
  // clicking "Start the quick setup" or "Skip". Once set, the welcome never
  // shows again (the wizard / checklist take over).
  welcomeShownAt       DateTime?
  // Set ONLY when the trainer explicitly opts into the tour — either by
  // clicking "Start the quick setup" on the welcome modal or "Take the
  // tour" on the backfill banner. Skip / No thanks do NOT set this.
  // Gates the floating onboarding FAB and the pulsing menu/in-page dots
  // — those are tour-only nudges, so before opt-in nothing should fire.
  tourStartedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile                  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  steps   TrainerOnboardingStepProgress[]
  emails  TrainerOnboardingEmailLog[]

  @@map("trainer_onboarding_progress")
}

// Per-trainer per-step state. `stepKey` is denormalised — no FK to
// OnboardingStep so admins can rename/delete steps without orphaning trainers.
model TrainerOnboardingStepProgress {
  id          String    @id @default(cuid())
  progressId  String
  stepKey     String
  startedAt   DateTime?
  completedAt DateTime?
  skippedAt   DateTime?

  progress TrainerOnboardingProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([progressId, stepKey])
  @@index([progressId])
  @@map("trainer_onboarding_step_progress")
}

// Idempotency log — `@@unique([progressId, emailKey])` prevents the cron
// sender from resending the same drip to the same trainer.
model TrainerOnboardingEmailLog {
  id         String   @id @default(cuid())
  progressId String
  emailKey   String
  sentAt     DateTime @default(now())

  progress TrainerOnboardingProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([progressId, emailKey])
  @@index([progressId])
  @@map("trainer_onboarding_email_logs")
}
