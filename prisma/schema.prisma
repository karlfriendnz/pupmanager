generator client {
  provider = "prisma-client-js"
  // Generate into the source tree so Vercel never serves a stale @prisma/client
  // from a cached node_modules between deploys. (Default node_modules/.prisma/
  // path was being cached across deploys, missing newly-added models.)
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  TRAINER
  CLIENT
  ADMIN
}

// A person's role *within a business* (distinct from the app-level Role above —
// every member is a TRAINER at the User level). OWNER is the founding account
// that holds billing; MANAGER has full operational access but not billing;
// STAFF sees only what's assigned to them. The role seeds a default permission
// set which the owner can then override per-member via TrainerMembership.permissions.
enum CompanyRole {
  OWNER
  MANAGER
  STAFF
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum ShareType {
  READ_ONLY
  CO_MANAGE
  TRANSFER
}

enum SessionType {
  IN_PERSON
  VIRTUAL
}

enum SessionStatus {
  UPCOMING
  COMPLETED
  COMMENTED
  INVOICED
}

enum AttachmentKind {
  IMAGE
  VIDEO
}

enum MessageChannel {
  TRAINER_CLIENT // visible to client
  TRAINER_TRAINER // private between trainers
}

enum CustomFieldType {
  TEXT
  NUMBER
  DROPDOWN
}

enum ProductKind {
  PHYSICAL
  DIGITAL
}

enum ProductRequestStatus {
  PENDING // client wants this, hasn't been delivered yet
  FULFILLED // trainer marked it delivered (linked to a session)
  CANCELLED // client withdrew the request, or trainer dismissed it
}

// ─── Core User ───────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  // Defaults to TRAINER so PrismaAdapter can create rows for OAuth (Apple/Google)
  // sign-ins which don't supply a role. Existing flows (Credentials sign-up,
  // invite acceptance) set role explicitly and override the default.
  role          Role      @default(TRAINER)
  emailVerified DateTime?
  image         String?
  timezone      String    @default("Pacific/Auckland")

  notifyEmail Boolean @default(true)
  notifyPush  Boolean @default(true)

  // Soft delete. When set, the account is "deactivated" — blocked from signing
  // in — but all its data is retained. Admins deactivate/reactivate from
  // /admin/trainers; we never hard-delete trainer accounts.
  deactivatedAt DateTime?

  // Timestamp of the most recent successful sign-in (any provider). Updated by
  // the NextAuth signIn event. Null = never signed in since this was added.
  // Surfaced in the admin trainers table as "Last seen".
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth
  accounts Account[]
  sessions Session[]

  // Role-specific profiles
  trainerProfile TrainerProfile?
  clientProfiles ClientProfile[]

  // Businesses this user belongs to as a trainer. The OWNER of a business has
  // both a trainerProfile (the business itself) AND an OWNER membership row;
  // invited members have only a membership (no trainerProfile of their own).
  // One membership per business — see TrainerMembership @@unique.
  memberships TrainerMembership[]

  // Messages sent by this user
  sentMessages Message[]

  // Push notification device tokens (one user can have multiple devices)
  deviceTokens DeviceToken[]

  // Per-(type, channel) preferences. Absence of a row means "use the default".
  notificationPreferences NotificationPreference[]

  // Dashboard scratchpad: one freeform brain-dump per (company, user), and the
  // to-do items this user created.
  brainDumps   TrainerBrainDump[]
  createdTodos TrainerTodo[]      @relation("TodoCreatedBy")

  @@map("users")
}

enum DevicePlatform {
  IOS
  ANDROID
}

// What kind of event a notification is for. Add new variants as we wire up
// more triggers — the preference matrix UI renders one row per type.
enum NotificationType {
  SESSION_REMINDER // n minutes before a TrainingSession starts
  SESSION_NOTES_REMINDER // n minutes before a TrainingSession ends — prompts the trainer to write session notes
  NEW_CLIENT_INVITE_ACCEPTED // a client used the invite link to sign up
  CLIENT_COMPLETED_TASKS // a client completed all of today's tasks
  NEW_MESSAGE // a new in-app message landed
  NEW_ENQUIRY // a public form (embed or intake) submission landed
  ENQUIRY_FOLLOWUP_REMINDER // a NEW enquiry has gone unanswered — nudges at 6/18/24/36h
  DAILY_SUMMARY // morning digest of today's sessions/tasks
  WEEKLY_SUMMARY // Sunday-evening wrap of the week + week-ahead glance
  STREAK_UPDATE // daily nudge about the trainer's weekly engagement streak
  // ─── Client-facing (the dog owner) ───
  CLIENT_ADDED_TO_PLAN // trainer added the client to a session / package / class
  CLIENT_SESSION_DIGEST // morning summary of the day's sessions
  CLIENT_SESSION_REMINDER // a heads-up n minutes before each session
  CLIENT_SESSION_CHANGED // a session was rescheduled or cancelled
  CLIENT_RECAP_READY // the trainer posted the write-up for a session
  CLIENT_NEW_MESSAGE // the trainer sent the client a message
}

enum NotificationChannel {
  PUSH
  EMAIL
  IN_APP // shows in the client's notifications feed
}

// Per-(user, type, channel) preference. Absence of a row means "use the
// type's default" (typically enabled). `minutesBefore` is only meaningful for
// time-relative types like SESSION_REMINDER; null otherwise.
model NotificationPreference {
  id            String              @id @default(cuid())
  userId        String
  // The organisation this preference applies to, for trainers who belong to
  // more than one. Null = the user's global/default row (also what every
  // pre-multi-org row is): the fallback when no per-org override exists, and
  // the only row client-audience prefs ever use.
  companyId     String?
  type          NotificationType
  channel       NotificationChannel
  enabled       Boolean             @default(true)
  // Time-relative (e.g. SESSION_REMINDER) — minutes before the event fires.
  minutesBefore Int?
  // Like minutesBefore but allows MULTIPLE lead times (e.g. client picks
  // "1 day before" + "2 hours before"). Empty = fall back to minutesBefore.
  leadMinutes   Int[]               @default([])
  // Time-of-day (e.g. DAILY_SUMMARY) — hour 0–23 in the user's timezone.
  dailyAtHour   Int?
  // Optional per-user copy overrides. Support {{placeholders}} that the
  // sender substitutes (e.g. {{dogName}}, {{startTime}}, {{count}}). Null
  // values fall back to the type's default template.
  customTitle   String?
  // Body override. For EMAIL-channel rows this may hold sanitized rich-text
  // HTML (authored in the editor); PUSH-channel rows stay plain text. Senders
  // convert HTML→text for push. @db.Text to fit formatted markup.
  customBody    String?             @db.Text
  // For DAILY_SUMMARY: when the trainer has zero sessions booked, swap
  // the morning digest for a warm "you can take the day off" message
  // instead of "0 sessions today" copy. Default true so existing
  // trainers get the friendlier behaviour without opting in.
  dayOffSummary Boolean             @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, type, channel])
  @@index([userId])
  @@map("notification_preferences")
}

model DeviceToken {
  id         String         @id @default(cuid())
  userId     String
  token      String         @unique
  platform   DevicePlatform
  createdAt  DateTime       @default(now())
  lastSeenAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ─── NextAuth Models ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Trainer Profile ─────────────────────────────────────────────────────────

model TrainerProfile {
  id                 String  @id @default(cuid())
  userId             String  @unique
  businessName       String
  // URL-safe handle for the public branded client-login page
  // (app.pupmanager.com/c/<slug>). Generated from businessName on demand,
  // editable in settings. Nullable until first generated.
  slug               String? @unique
  // The trainer's phone number — always on file (required at signup, enforced by
  // the (trainer) layout gate). Shown to clients (my-help page + in-app "Call"
  // button) ONLY when showPhoneToClients is true.
  phone              String?
  // Opt-in: whether `phone` is shown to clients. Default false = private (kept
  // for PupManager/ops only); the trainer ticks a box to publish it. Backfilled
  // true for accounts that had a phone before this flag existed, to preserve
  // their prior always-shown behaviour.
  showPhoneToClients Boolean @default(false)
  logoUrl            String?
  website            String? // public website URL, shown to clients as a link in the app header
  publicEmail        String? // public contact email shown to clients (may differ from login email)
  dashboardBgUrl     String? // background image shown on the client home dashboard
  inviteTemplate     String? @db.Text // customisable invite email template
  // Hex colour for the accent strip across the top of outbound emails.
  // Falls back to a violet default when null.
  emailAccentColor   String?
  // Client-app accent gradient — start + end hex. Drive --accent and
  // --accent-strong in the (client) shell. Null falls back to emailAccentColor
  // (start) / a derived darker shade (end), else the PupManager teal default.
  appGradientStart   String?
  appGradientEnd     String?
  // Short personal welcome shown to clients on their app home (set in the
  // first-run personalization wizard, editable later in settings).
  clientWelcomeNote  String? @db.Text

  // Google Calendar integration
  googleCalendarRefreshToken String? @db.Text
  googleCalendarConnected    Boolean @default(false)

  // Schedule view preferences — controls the visible hour range and which
  // weekdays render in the week grid. Days are 1=Mon..7=Sun.
  // The base scheduleStart/EndHour pair drives the desktop grid; the
  // mobile pair (nullable) overrides on phones so trainers can run a
  // tighter window on small screens. Null = fall back to the base pair.
  scheduleStartHour         Int     @default(7) // inclusive
  scheduleEndHour           Int     @default(21) // exclusive (last hour shown is end-1)
  scheduleMobileStartHour   Int? // mobile-only override; null falls back to scheduleStartHour
  scheduleMobileEndHour     Int? // mobile-only override; null falls back to scheduleEndHour
  scheduleDays              Json    @default("[1,2,3,4,5,6,7]")
  // Up to 2 extra fields rendered on schedule blocks. Allowed ids:
  // "location" | "description" | "sessionType" | "duration" | "title"
  scheduleExtraFields       Json    @default("[]")
  // Ordered list of intake-form section names (string[]). Lets trainers create
  // empty sections and drag fields into them; without this, a section only
  // "existed" if at least one field had that category. Fields whose category
  // doesn't appear in this list pile into a "Fields without a section" bucket.
  intakeSectionOrder        Json    @default("[]")
  // Whether the intake form is published (visible to clients). Defaults to
  // false so newly-seeded intake fields don't go live until the trainer
  // explicitly publishes from the intake editor.
  intakeFormPublished       Boolean @default(false)
  // Per-trainer assignment of the three core "system" intake fields
  // (name, email, phone) to a section in intakeSectionOrder. Shape:
  // { name?: string|null, email?: string|null, phone?: string|null }.
  // null/missing for any key = orphan (renders alongside fields that
  // also lack a section). Stored separately from CustomField.category
  // because the system fields aren't custom fields — they back real
  // columns on User/ClientProfile.
  intakeSystemFieldSections Json    @default("{}")
  // Per-company config for the built-in client/dog fields when CREATING a
  // client (the full create form + the quick-add contact form). Shape:
  // { "<fieldKey>": { required?: boolean, quickAdd?: boolean } } where fieldKey
  // is one of name|email|phone|address|dogName|dogBreed|dogWeight|dogDob|dogNotes.
  // `required` = required in the full create form; `quickAdd` = shown in (and
  // required for) the quick-add form. Missing keys fall back to the defaults in
  // src/lib/client-fields.ts. Custom fields carry their own required/inQuickAdd.
  clientFieldConfig         Json    @default("{}")
  // Trainer-chosen visible columns on /clients. Allowed ids:
  // "email" | "dog" | "breed" | "extraDogs" | "nextSession" | "compliance" | "shared" | "custom:<id>"
  clientListColumns         Json    @default("[\"email\",\"dog\",\"nextSession\",\"compliance\"]")
  // Grouping for /clients. null = flat list. "nextDay" = group by day of
  // next booking. "custom:<id>" = group by custom-field value.
  clientListGroupBy         String?

  // Subscription
  subscriptionPlanId   String?
  subscriptionStatus   SubscriptionStatus @default(TRIALING)
  // When the free trial expires. Stamped on signup (now + 14 days). Null
  // for paid plans that don't have a trial window or trainers who never
  // had one (legacy accounts).
  trialEndsAt          DateTime?
  // Stripe identifiers — populated lazily, the first time the trainer
  // hits Checkout. Customer is reused across plan changes; subscription
  // and price flip when they upgrade/downgrade.
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  // End of the current paid period — drives the "renews on …" copy and
  // the access-cutoff job for cancelled subscriptions.
  currentPeriodEnd     DateTime?
  // Admin-granted grace period. When set and in the future, the trainer
  // keeps full platform access regardless of trial/subscription state —
  // an escape hatch for comped accounts, support cases, or payment hiccups.
  // Set per-trainer from /admin/trainers. Null = no grace.
  gracePeriodUntil     DateTime?
  // Dual-mode billing: when true this trainer bills against Stripe TEST mode
  // (sandbox) — the test secret key + the *Test price columns — so the demo
  // account can show the full billing flow without ever taking a real charge
  // while everyone else is on live Stripe.
  sandboxBilling       Boolean            @default(false)
  // Internal/test account flag. When true this is a PupManager-owned account
  // (our own testing/demo logins), not a real customer. Set from
  // /admin/trainers so we can visually tag — and later exclude from metrics —
  // accounts that are "ours".
  isInternal           Boolean            @default(false)
  // ISO 3166-1 alpha-2 country code captured from the signup request's IP geo
  // (Vercel's x-vercel-ip-country) at account creation. Null for older accounts
  // / signups without geo. Surfaced as a flag in /admin/trainers.
  signupCountry        String?
  // Number of trainer seats the subscription was booked for. Mirrors
  // the Stripe subscription's quantity. 1 by default; bumps via the
  // slider on /billing/setup.
  seatCount            Int                @default(1)
  // Founders Circle: the first FOUNDER_SEATS (10) trainers to subscribe
  // get a Stripe coupon that holds the founder rate for 12 months, then
  // the subscription auto-reverts to standard pricing (the coupon's
  // `duration_in_months` handles the revert — no scheduled job). Stamped
  // by the Stripe webhook on checkout completion, not at checkout
  // creation, so an abandoned checkout never burns a founder seat. The
  // Stripe coupon's own max_redemptions is the hard cap; this flag drives
  // the "N of 10 left" gate and founder copy.
  isFounder            Boolean            @default(false)
  founderClaimedAt     DateTime?
  // Business postal address — captured on /billing/setup, used for
  // Stripe customer billing details, invoice rendering, and tax-region
  // reporting. All optional so existing trainers don't get blocked.
  addressLine1         String?
  addressLine2         String?
  addressCity          String?
  addressRegion        String?
  addressPostcode      String?
  addressCountry       String?
  // The promo code (if any) this trainer redeemed at signup — it set their
  // trialEndsAt. Kept for attribution and so the admin can see redemptions.
  promoCodeId          String?
  // Route manager start/end point ("leave from and return to base"). Captured
  // via Places Autocomplete; lat/lng come from the picked place. Null = the
  // route manager asks them to set a base before optimising.
  baseAddress          String?
  baseLat              Float?
  baseLng              Float?
  basePlaceId          String?

  // ─── Stripe Connect (Flow B: client→trainer payments) ──────────────────────
  // Separate money flow from the trainer's own subscription above. The trainer
  // onboards a Stripe Connect *Express* account; clients pay them via hosted
  // Checkout (destination charge), Stripe takes our application fee and pays
  // the trainer out. None of the stripeCustomerId/stripeSubscriptionId fields
  // above are involved — those are the trainer's subscription TO PupManager.
  connectAccountId          String?   @unique // acct_… (Express). Null = not started.
  connectChargesEnabled     Boolean   @default(false) // mirrors account.charges_enabled
  connectPayoutsEnabled     Boolean   @default(false) // mirrors account.payouts_enabled
  connectDetailsSubmitted   Boolean   @default(false) // account.details_submitted (KYC done)
  connectOnboardedAt        DateTime? // first time charges + payouts both true
  // Trainer's payout / pricing currency for client payments — ISO 4217
  // lower-case (Stripe convention). Seeded from signupCountry on first onboard.
  // SEPARATE from the per-checkout currency used by the subscription flow.
  payoutCurrency            String?
  // Master switch the trainer flips once onboarded — lets them connect but keep
  // prices display-only until they're ready to actually take payments. Defaults
  // ON (and the connect webhook turns it on at onboarding) so a freshly-
  // connected trainer can take payments without flipping another switch.
  acceptPaymentsEnabled     Boolean   @default(true)
  // When true, the card processing fee is added on top of the price at checkout
  // (the client pays it) instead of being absorbed by the trainer, so the
  // trainer nets the full amount. On by default — trainers can opt out.
  passProcessingFeeToClient Boolean   @default(true)

  // ─── Bulk-email sending domain (Resend) ─────────────────────────────────────
  // To send bulk emails to their clients the trainer must verify a *sending
  // subdomain* of their own domain (e.g. mail.theirbusiness.com) — sending off a
  // subdomain keeps the broadcast reputation off the root domain and is Resend's
  // recommended setup. `sendingDomain` is what they entered (mail.theirbiz.com);
  // `resendDomainId` is the Resend domain record id we poll for verification;
  // `sendingFromEmail` is the resolved verified From (hello@mail.theirbiz.com);
  // `domainVerifiedAt` is stamped once Resend reports the domain verified — the
  // bulk-send route hard-blocks until it is non-null.
  sendingDomain         String?
  resendDomainId        String?   @unique
  sendingFromEmail      String?
  domainVerifiedAt      DateTime?
  // Lets the trainer try bulk email immediately on PupManager's shared verified
  // sender ("<Name> via PupManager") WITHOUT verifying their own domain — a
  // test/trial escape hatch. The trial daily cap still applies. Verifying their
  // own domain is the production path; this just unblocks a first send.
  useTrialSendingDomain Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan   SubscriptionPlan?          @relation(fields: [subscriptionPlanId], references: [id])
  promoCode          PromoCode?                 @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  clients            ClientProfile[]
  sharedClients      ClientShare[]              @relation("SharedByTrainer")
  receivedClients    ClientShare[]              @relation("SharedWithTrainer")
  trainingSessions   TrainingSession[]
  trainingTemplates  TrainingTemplate[]
  customFields       CustomField[]
  libraryTypes       LibraryType[]
  embedForms         EmbedForm[]
  enquiries          Enquiry[]
  emailTemplates     EmailTemplate[]
  broadcasts         EmailBroadcast[]
  timeRates          TimeRate[]
  timesheets         Timesheet[]
  sentNotifications  ClientNotification[]
  availabilitySlots  AvailabilitySlot[]
  blackoutPeriods    BlackoutPeriod[]
  bookingPages       BookingPage[]
  leadMagnets        LeadMagnet[]
  subscribers        Subscriber[]
  packages           Package[]
  sessionForms       SessionForm[]
  products           Product[]
  achievements       Achievement[]
  classRuns          ClassRun[]
  waitlistEntries    WaitlistEntry[]
  bookingRequests    BookingRequest[]
  activityWeeks      TrainerActivityWeek[]
  badgeAwards        TrainerBadgeAward[]
  onboardingProgress TrainerOnboardingProgress?
  members            TrainerMembership[]        @relation("CompanyMembers")
  addons             TrainerAddon[]
  payments           Payment[]
  brainDumps         TrainerBrainDump[]
  todos              TrainerTodo[]

  @@map("trainer_profiles")
}

// ─── Promo codes ──────────────────────────────────────────────────────────────
// A shared code a trainer enters at signup. When valid it SETS their total
// trial length (trialEndsAt = signup + trialDays) instead of the default 10.
// One code is reusable by many trainers; optional expiry + redemption cap.
model PromoCode {
  id             String    @id @default(cuid())
  // Stored upper-cased; lookups upper-case the entered value so it's
  // case-insensitive without a functional index.
  code           String    @unique
  // Total trial length (in days) granted when this code is used.
  trialDays      Int
  // Null = never expires. A code past this instant no longer redeems.
  expiresAt      DateTime?
  // Null = unlimited. Once redeemedCount reaches this, the code stops working.
  maxRedemptions Int?
  redeemedCount  Int       @default(0)
  // Lets an admin pause a code without deleting it (and losing attribution).
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  redemptions TrainerProfile[]

  @@map("promo_codes")
}

// ─── Trainer Memberships (multi-trainer businesses) ───────────────────────────
// One row per (business, person). The business is a TrainerProfile (the tenant
// every other model already scopes to via trainerId); a member is a User who
// logs in with their own account. The founding owner has an OWNER row here in
// addition to owning the TrainerProfile, so sessions/clients can be assigned to
// them uniformly. Invited trainers have ONLY a membership (no trainerProfile),
// and resolve their company via this row in the auth callbacks.
model TrainerMembership {
  id          String      @id @default(cuid())
  companyId   String // → TrainerProfile.id (the business / tenant)
  userId      String // → User.id (the member's login)
  role        CompanyRole @default(STAFF)
  // Optional display title shown on the schedule / team list ("Senior trainer").
  title       String?
  // Granular permission overrides layered on top of the role preset. Flat map
  // of permissionKey → boolean, e.g. {"packages.manage": true, "billing.view": false}.
  // A missing key falls back to the role's default for that permission, so an
  // empty object means "use the role preset verbatim". OWNER ignores this map
  // (always full access). See src/lib/permissions.ts for the catalogue + defaults.
  permissions Json        @default("{}")
  // Invite lifecycle. invitedAt stamps creation; acceptedAt is null while the
  // invite is outstanding and set once the member first signs in / accepts.
  invitedAt   DateTime    @default(now())
  acceptedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company TrainerProfile @relation("CompanyMembers", fields: [companyId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Work assigned to this member. SetNull (not Cascade) so removing a member
  // leaves their sessions/clients intact but unassigned, for reassignment.
  assignedSessions TrainingSession[] @relation("AssignedTrainer")
  assignedClients  ClientProfile[]   @relation("AssignedTrainer")

  // Time this member has logged against sessions (billable hours).
  timeEntries SessionTimeEntry[] @relation("TimeEntryMember")

  // Group classes (ClassRun) this member is assigned to run.
  assignedClassRuns ClassRunTrainer[]

  // Dashboard to-do items assigned to this member.
  assignedTodos TrainerTodo[] @relation("TodoAssignee")

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@map("trainer_memberships")
}

// Per-member time logged against a single session — billable hours. Several
// members can each log time on the same session ("Sam logged 1.5h, Sally 0.5h").
// minutes is the duration; rateCents is the hourly rate used to bill it (null =
// not billable / rate not set). loggedById records who entered it (audit only).
model SessionTimeEntry {
  id           String  @id @default(cuid())
  sessionId    String
  membershipId String // whose time this is → TrainerMembership.id
  minutes      Int // duration in minutes
  rateCents    Int? // hourly rate in cents; null = non-billable
  note         String? @db.Text
  loggedById   String? // membership that recorded the entry (audit, no FK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session    TrainingSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  membership TrainerMembership @relation("TimeEntryMember", fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([membershipId])
  @@map("session_time_entries")
}

// ─── Timesheets ──────────────────────────────────────────────────────────────

// A named, reusable hourly rate the business defines (e.g. "Training" $80/hr,
// "Travel" $40/hr). Time entries pick one; the entry snapshots the rate so
// editing/archiving a rate later doesn't rewrite finalised timesheets.
model TimeRate {
  id         String    @id @default(cuid())
  companyId  String // → TrainerProfile.id
  name       String
  rateCents  Int // hourly rate in cents (company currency)
  archivedAt DateTime? // hidden from new pickers but kept for history
  sortOrder  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company TrainerProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries TimeEntry[]

  @@index([companyId])
  @@map("time_rates")
}

// A weekly timesheet owned by one staff member. DRAFT while editable; FINALISED
// locks the entries and stamps finalisedAt. recipientEmail/sentAt track the
// emailed PDF (defaults to the company owner on send).
model Timesheet {
  id             String    @id @default(cuid())
  companyId      String // → TrainerProfile.id (tenant)
  userId         String // → User.id (whose timesheet — owner or staff member)
  weekStart      DateTime  @db.Date // Monday of the week (date only)
  title          String?
  status         String    @default("DRAFT") // "DRAFT" | "FINALISED"
  notes          String?   @db.Text
  recipientEmail String?
  finalisedAt    DateTime?
  sentAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company TrainerProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries TimeEntry[]

  @@index([companyId, userId, weekStart])
  @@map("timesheets")
}

// One line on a timesheet: a dated task with a duration and (optional) rate.
// minutes is the duration source of truth; rateCents/rateName snapshot the
// chosen TimeRate; amountCents = round(minutes/60 * rateCents) (or a manual
// amount). Optionally tied to a client.
model TimeEntry {
  id          String   @id @default(cuid())
  timesheetId String
  date        DateTime @db.Date
  task        String
  minutes     Int      @default(0)
  rateId      String? // → TimeRate.id (null = manual/no rate)
  rateName    String? // snapshot of the rate name at entry time
  rateCents   Int? // snapshot of the hourly rate in cents
  amountCents Int      @default(0) // computed (or manually overridden) line total
  clientId    String? // → ClientProfile.id (optional association)
  category    String?
  notes       String?  @db.Text
  sortOrder   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timesheet Timesheet      @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  rate      TimeRate?      @relation(fields: [rateId], references: [id], onDelete: SetNull)
  client    ClientProfile? @relation("ClientTimeEntries", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([timesheetId])
  @@index([clientId])
  @@map("time_entries")
}

// ─── Client & Dog ────────────────────────────────────────────────────────────

model ClientProfile {
  id                   String  @id @default(cuid())
  // A user can hold several client relationships — one per trainer (tenant).
  // Uniqueness is therefore on the (userId, trainerId) pair, not userId alone.
  userId               String
  trainerId            String // owning business (TrainerProfile = tenant)
  // The member trainer this client is assigned to within the business. Null =
  // unassigned (visible to owner/managers; not to any single staff member).
  // Distinct from trainerId, which is the tenant the client's data lives under.
  assignedMembershipId String?
  dogId                String? // set after onboarding
  status               String  @default("ACTIVE") // "ACTIVE" | "INACTIVE"
  // Auto-generated "Sample" client seeded by the first-run personalization
  // wizard so a brand-new trainer can preview the client app. Removed on
  // demand or when the trainer adds their first real client.
  isSample             Boolean @default(false)
  // Contact phone for the client (collected on intake). Lives on the
  // profile, not on User, mirroring TrainerProfile.phone — phone is a
  // per-trainer-relationship attribute (a client may share a phone
  // with another household member who has their own User row).
  phone                String?
  // Visit location for the route manager. Captured via Places Autocomplete, so
  // lat/lng come from the picked place (no separate geocoding call). placeId is
  // kept for re-lookup/dedup. All null until an address is set.
  addressLine          String?
  addressLat           Float?
  addressLng           Float?
  addressPlaceId       String?

  // Set when an invitation email is actually sent to the client (via the
  // invite form with notifications on, or a re-invite). Null = the client
  // record was created/added but never invited. Powers the "Invite your
  // first client" onboarding step, kept distinct from "Create a client".
  invitedAt DateTime?

  // Bulk/marketing email opt-out, scoped to THIS trainer relationship (matching
  // the composite (userId, trainerId) model — a person can be opted out for one
  // trainer but not another). Set either by the client clicking Unsubscribe in a
  // broadcast footer, or automatically when Resend reports a hard bounce /
  // spam complaint (suppression). Transactional 1:1 messages ignore this; only
  // bulk broadcasts respect it. `marketingOptOutReason` records why.
  marketingEmailOptOut  Boolean   @default(false)
  marketingOptOutAt     DateTime?
  marketingOptOutReason String? // "UNSUBSCRIBED" | "BOUNCED" | "COMPLAINED"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainer         TrainerProfile     @relation(fields: [trainerId], references: [id])
  assignedTrainer TrainerMembership? @relation("AssignedTrainer", fields: [assignedMembershipId], references: [id], onDelete: SetNull)
  dog             Dog?               @relation("PrimaryDog", fields: [dogId], references: [id])

  diaryEntries      TrainingTask[]
  trainingSessions  TrainingSession[]
  classEnrollments  ClassEnrollment[]
  waitlistEntries   WaitlistEntry[]
  bookingRequests   BookingRequest[]
  shares            ClientShare[]
  messages          Message[]            @relation("ClientMessages")
  customFieldValues CustomFieldValue[]
  dogs              Dog[]                @relation("AdditionalDogs")
  timeEntries       TimeEntry[]          @relation("ClientTimeEntries")
  notifications     ClientNotification[]
  clientPackages    ClientPackage[]
  productRequests   ProductRequest[]
  buddySessions     SessionBuddy[]
  achievements      ClientAchievement[]
  payments          Payment[]
  enquiry           Enquiry?

  @@unique([userId, trainerId])
  @@index([userId])
  @@index([trainerId])
  @@index([assignedMembershipId])
  @@map("client_profiles")
}

model Dog {
  id              String    @id @default(cuid())
  name            String
  breed           String?
  weight          Float? // kg
  dob             DateTime?
  photoUrl        String?
  notes           String?   @db.Text
  clientProfileId String? // owner (for additional dogs in a household)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  primaryFor       ClientProfile[]   @relation("PrimaryDog")
  owner            ClientProfile?    @relation("AdditionalDogs", fields: [clientProfileId], references: [id])
  sessions         TrainingSession[]
  tasks            TrainingTask[]
  buddySessions    SessionBuddy[]
  classEnrollments ClassEnrollment[]
  media            DogMedia[]

  @@index([clientProfileId])
  @@map("dogs")
}

// Trainer-curated photo/video gallery for a dog. Surfaced as the hero on the
// client home + dog profile. Mirrors session_attachments (public Blob URLs,
// unguessable pathnames; the API endpoints enforce trainer ownership).
model DogMedia {
  id           String         @id @default(cuid())
  dogId        String
  trainerId    String // denormalised for fast permission checks
  kind         AttachmentKind
  url          String
  thumbnailUrl String? // client-generated still for video previews
  caption      String?        @db.Text
  order        Int            @default(0)

  createdAt DateTime @default(now())

  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)

  @@index([dogId])
  @@index([trainerId])
  @@map("dog_media")
}

// ─── Client Sharing ───────────────────────────────────────────────────────────

model ClientShare {
  id           String    @id @default(cuid())
  clientId     String
  sharedById   String
  sharedWithId String
  shareType    ShareType
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())

  client     ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sharedBy   TrainerProfile @relation("SharedByTrainer", fields: [sharedById], references: [id])
  sharedWith TrainerProfile @relation("SharedWithTrainer", fields: [sharedWithId], references: [id])

  @@index([clientId])
  @@index([sharedWithId])
  @@map("client_shares")
}

// ─── Training Diary & Tasks ───────────────────────────────────────────────────

model TrainingTask {
  id          String   @id @default(cuid())
  clientId    String
  dogId       String? // optional: which dog this task is for
  sessionId   String? // optional: linked training session
  date        DateTime @db.Date
  title       String
  description String?  @db.Text
  repetitions Int?
  videoUrl    String? // trainer-provided instructional link
  trainerNote String?  @db.Text // per-task comment from the trainer
  imageUrls   Json     @default("[]") // string[] of public image URLs
  order       Int      @default(0) // display order within a session

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     ClientProfile    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dog        Dog?             @relation(fields: [dogId], references: [id])
  session    TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  completion TaskCompletion?

  @@index([clientId])
  @@index([date])
  @@index([sessionId])
  @@map("training_tasks")
}

model TaskCompletion {
  id          String   @id @default(cuid())
  taskId      String   @unique
  completedAt DateTime @default(now())
  note        String?  @db.Text
  videoUrl    String? // client-submitted link
  videoS3Key  String? // native video upload (S3)

  task TrainingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_completions")
}

// ─── Scheduling ──────────────────────────────────────────────────────────────

model TrainingSession {
  id                   String        @id @default(cuid())
  trainerId            String // owning business (tenant)
  // The member trainer running this session. Null = unassigned (sole-trainer
  // businesses leave this null; the owner is implied). Drives the calendar
  // colour/filter and staff scoping in multi-trainer businesses.
  assignedMembershipId String?
  clientId             String? // direct client link (optional, in addition to dogId)
  dogId                String?
  clientPackageId      String? // membership in an assigned package
  // Group classes: a shared session belongs to a ClassRun (cohort) rather
  // than a single client. For group sessions clientId/dogId stay null —
  // attendance is tracked per-enrollee via SessionAttendance. sessionIndex
  // is the 1-based position within the run ("session 3 of 6"), also the
  // join point used for drop-in pricing.
  classRunId           String?
  sessionIndex         Int?
  // Links the sessions of a recurring "buddies walk" (a group dog walk created
  // from the schedule). Lets a dog added later be applied to just this walk,
  // this + following walks, or the whole series. Null for non-walk sessions.
  walkSeriesId         String?
  // Per-session session-form override for class sessions. Null = inherit the
  // class's default form (the group package's defaultSessionFormId). Lets a run
  // use one form for most sessions and a different one on, say, the last.
  sessionFormId        String?
  // The booking page this session was created from (instant book, accepted
  // prospect, or confirmed request). Drives BEFORE/AFTER_SESSION automations.
  // SetNull so deleting the page leaves the session intact.
  bookingPageId        String?
  title                String
  description          String?       @db.Text
  scheduledAt          DateTime
  durationMins         Int           @default(60)
  sessionType          SessionType   @default(IN_PERSON)
  status               SessionStatus @default(UPCOMING)
  // Whether the trainer has invoiced this session (Xero/QBO/manual). Tracked
  // separately from `status` because invoicing can happen before OR after the
  // session is marked complete — the lifecycles are orthogonal. Null = not
  // invoiced; set = invoiced at this timestamp.
  invoicedAt           DateTime?
  location             String?
  virtualLink          String?

  googleCalendarEventId String?

  // Set when the "starting in ~20 min" push reminder has been delivered to the
  // trainer, so the cron loop never sends two pushes for the same session.
  reminderPushSentAt        DateTime?
  // Same idea for the "ends in ~5 min — write session notes" reminder.
  notesReminderPushSentAt   DateTime?
  // Set when this session was rescheduled but the client hasn't been told yet.
  // The trainer batch-sends pending reschedules from a banner, so dragging
  // sessions around doesn't fire a notification on every move.
  rescheduleNotifyPendingAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer                  TrainerProfile          @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  assignedTrainer          TrainerMembership?      @relation("AssignedTrainer", fields: [assignedMembershipId], references: [id], onDelete: SetNull)
  client                   ClientProfile?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  dog                      Dog?                    @relation(fields: [dogId], references: [id])
  clientPackage            ClientPackage?          @relation(fields: [clientPackageId], references: [id], onDelete: SetNull)
  tasks                    TrainingTask[]
  formResponses            SessionFormResponse[]
  fulfilledProductRequests ProductRequest[]
  buddies                  SessionBuddy[]
  attachments              SessionAttachment[]
  classRun                 ClassRun?               @relation(fields: [classRunId], references: [id], onDelete: Cascade)
  attendance               SessionAttendance[]
  bookingPage              BookingPage?            @relation(fields: [bookingPageId], references: [id], onDelete: SetNull)
  automationSends          BookingAutomationSend[]
  paymentItem              PaymentItem?
  timeEntries              SessionTimeEntry[]

  @@index([trainerId])
  @@index([assignedMembershipId])
  @@index([clientId])
  @@index([scheduledAt])
  @@index([bookingPageId])
  // Composite for the hot path: "this trainer's sessions in a date range"
  // (schedule grid, dashboard, route day) — one index scan instead of
  // filtering a trainerId or scheduledAt index.
  @@index([trainerId, scheduledAt])
  @@index([clientPackageId])
  @@index([classRunId])
  @@index([walkSeriesId])
  @@map("training_sessions")
}

// Trainer-uploaded media attached to a session — photos and short clips
// captured during/after a session and surfaced in the session detail
// page. Lives in Vercel Blob (no transcoding) for v1; if/when we move
// video to a streaming service the schema can grow a `provider` enum
// without changing call sites.
model SessionAttachment {
  id           String         @id @default(cuid())
  sessionId    String
  trainerId    String // denormalised for fast permission checks
  kind         AttachmentKind
  // Public Blob URL. We don't gate access via signing for v1 — the
  // pathname includes the session + attachment id so URLs are
  // unguessable, and the API endpoints that hand them out enforce
  // trainer ownership.
  url          String
  // Optional client-generated thumbnail still for video previews.
  thumbnailUrl String?
  // Free-form caption / note the trainer can add when uploading.
  caption      String?        @db.Text
  // Stored for display ("12 sec") and for soft-quota calculations later.
  sizeBytes    Int
  durationMs   Int? // videos only

  createdAt DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([trainerId])
  @@map("session_attachments")
}

// "Buddy session" — additional client/dog pairs attending a TrainingSession
// alongside the primary client/dog. Trainer-only visibility (the buddy client's
// portal does not surface these). Same client may appear twice with two
// different dogs, so the unique key includes dogId.
model SessionBuddy {
  id        String   @id @default(cuid())
  sessionId String
  clientId  String
  dogId     String?
  createdAt DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  client  ClientProfile   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dog     Dog?            @relation(fields: [dogId], references: [id], onDelete: SetNull)

  @@unique([sessionId, clientId, dogId])
  @@index([sessionId])
  @@index([clientId])
  @@map("session_buddies")
}

// ─── Products (trainer shop) ─────────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  trainerId   String
  isSample    Boolean     @default(false)
  name        String
  description String?     @db.Text
  kind        ProductKind @default(PHYSICAL)
  // Price in cents to avoid float issues. Null = unpriced / "Contact trainer".
  priceCents  Int?
  imageUrl    String?
  // Required for DIGITAL products — the file the customer downloads. Public URL
  // (e.g. Vercel Blob) or signed URL handed out at access time.
  downloadUrl String?
  category    String? // free-form trainer-defined grouping ("Treats", "Guides")
  featured    Boolean     @default(false) // surfaces on the client home dashboard
  active      Boolean     @default(true) // hide from clients without deleting
  order       Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer      TrainerProfile   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  requests     ProductRequest[]
  paymentItems PaymentItem[]

  @@index([trainerId])
  @@index([category])
  @@map("products")
}

// A client's standing request for a product. Stays PENDING and rolls forward
// onto each successive upcoming session until the trainer marks it FULFILLED
// (typically because they handed the item over at a session) or CANCELLED.
model ProductRequest {
  id        String               @id @default(cuid())
  clientId  String
  productId String
  status    ProductRequestStatus @default(PENDING)

  // Optional notes from the client when they request (e.g. "for Bella, size L")
  note String? @db.Text

  // Set when trainer fulfils the request — links it to the session where it
  // was delivered, for the trainer's own records.
  fulfilledSessionId String?
  fulfilledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client           ClientProfile    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  fulfilledSession TrainingSession? @relation(fields: [fulfilledSessionId], references: [id], onDelete: SetNull)

  @@index([clientId, status])
  @@index([productId])
  @@map("product_requests")
}

// ─── Packages ─────────────────────────────────────────────────────────────────

model Package {
  id                       String      @id @default(cuid())
  trainerId                String
  // True for rows created by the trainer-facing "sample data" loader, so
  // clearSampleData() can remove them without touching the trainer's real data.
  isSample                 Boolean     @default(false)
  name                     String
  description              String?     @db.Text
  sessionCount             Int         @default(3)
  weeksBetween             Int         @default(2) // gap between sessions, in weeks
  durationMins             Int         @default(60) // default duration applied to created sessions
  sessionType              SessionType @default(IN_PERSON)
  // Prices in cents to avoid float precision issues. specialPriceCents is an
  // optional discounted price the trainer can offer for promotions, etc.
  priceCents               Int? // null = unpriced
  specialPriceCents        Int? // null = no special price
  // Optional schedule colour (Tailwind palette key, eg "blue"). When set,
  // sessions assigned to this package render in that colour on the calendar.
  color                    String?
  order                    Int         @default(0) // display order, lowest first
  // Optional default session form. When a session is opened with this package
  // and no form responses exist, the default form is auto-attached.
  defaultSessionFormId     String?
  // When false, suppress the SESSION_NOTES_REMINDER push for sessions in this
  // package. Some packages (e.g. drop-in classes) don't need a follow-up.
  // Defaults to true so existing packages keep firing reminders.
  requireSessionNotes      Boolean     @default(true)
  // ─── Group classes ──────────────────────────────────────────────────────
  // When isGroup, the package is a sellable class template. A trainer
  // schedules one or more ClassRuns (cohorts) off it; each run owns ONE
  // shared session series that many clients enrol into. isGroup=false
  // packages keep the 1:1 ClientPackage path untouched.
  isGroup                  Boolean     @default(false)
  // Max enrolments per run (null = unlimited). A run may override this.
  capacity                 Int?
  // Allow clients to join a run after it has started (rolling drop-in),
  // paying per remaining session at dropInPriceCents.
  allowDropIn              Boolean     @default(false)
  dropInPriceCents         Int?
  // Full runs accept a waitlist that auto-promotes on withdrawal.
  allowWaitlist            Boolean     @default(false)
  // Exposed on the public embed surface for client self-enrolment.
  publicEnrollment         Boolean     @default(false)
  // Client self-booking from their availability tab. clientSelfBook
  // opts the package in; selfBookRequiresApproval gates whether the
  // pick creates a pending BookingRequest (true) or books instantly
  // (false). Only meaningful when clientSelfBook is true.
  clientSelfBook           Boolean     @default(false)
  selfBookRequiresApproval Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer            TrainerProfile   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  assignments        ClientPackage[]
  classRuns          ClassRun[]
  waitlistEntries    WaitlistEntry[]
  bookingRequests    BookingRequest[]
  bookingPages       BookingPage[]
  defaultSessionForm SessionForm?     @relation("PackageDefaultSessionForm", fields: [defaultSessionFormId], references: [id], onDelete: SetNull)

  @@index([trainerId])
  @@index([defaultSessionFormId])
  @@map("packages")
}

model ClientPackage {
  id                 String    @id @default(cuid())
  packageId          String
  clientId           String
  startDate          DateTime
  assignedAt         DateTime  @default(now())
  // When true, the schedule auto-creates more sessions on the package's
  // cadence so the calendar always has ~6 weeks of sessions ahead.
  extendIndefinitely Boolean   @default(false)
  // Manual flag the trainer ticks when they've sent the invoice for this
  // assignment outside PupManager (Xero/QBO/cash). Null = not invoiced yet.
  // Once we wire real billing this is what the financial layer keys off.
  invoicedAt         DateTime?

  package     Package           @relation(fields: [packageId], references: [id], onDelete: Cascade)
  client      ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessions    TrainingSession[]
  paymentItem PaymentItem?

  @@index([clientId])
  @@index([packageId])
  @@map("client_packages")
}

// ─── Group classes ────────────────────────────────────────────────────────────

enum ClassRunStatus {
  SCHEDULED // created, may still be taking enrolments before it starts
  RUNNING // first session has happened
  COMPLETED // all sessions done
  CANCELLED // called off; sessions cancelled, enrolments closed
}

enum EnrollmentType {
  FULL // enrolled for the whole run from the start
  DROP_IN // joined mid-run, pays per remaining session
}

enum EnrollmentStatus {
  ENROLLED
  WAITLISTED
  WITHDRAWN
  COMPLETED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  MAKEUP // attended a different run's session to make this one up
}

// A scheduled cohort of a group Package. Owns ONE shared TrainingSession
// series (sessions have classRunId set, clientId null). Capacity falls
// back to the package's when null here.
model ClassRun {
  id           String         @id @default(cuid())
  trainerId    String
  isSample     Boolean        @default(false)
  packageId    String
  name         String // e.g. "Spring Puppy Class"
  scheduleNote String? // human cadence, e.g. "Tuesdays 6:00pm"
  startDate    DateTime
  capacity     Int? // per-run override of Package.capacity
  imageUrl     String? // optional cover image (Vercel Blob URL)
  status       ClassRunStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer          TrainerProfile    @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  package          Package           @relation(fields: [packageId], references: [id], onDelete: Restrict)
  sessions         TrainingSession[]
  enrollments      ClassEnrollment[]
  assignedTrainers ClassRunTrainer[]

  @@index([trainerId])
  @@index([packageId])
  @@map("class_runs")
}

// Join model: which team members (TrainerMembership rows) are assigned to run
// a ClassRun. A ClassRun belongs to one company (trainerId); this lets one or
// more of that company's members be tagged as the trainer(s) on it.
model ClassRunTrainer {
  id           String   @id @default(cuid())
  classRunId   String
  membershipId String
  createdAt    DateTime @default(now())

  classRun   ClassRun          @relation(fields: [classRunId], references: [id], onDelete: Cascade)
  membership TrainerMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([classRunId, membershipId])
  @@index([classRunId])
  @@index([membershipId])
  @@map("class_run_trainers")
}

// A client+dog's membership in a ClassRun. Replaces ClientPackage for the
// group path. Waitlist is a status + position, auto-promoted on withdrawal.
model ClassEnrollment {
  id               String           @id @default(cuid())
  classRunId       String
  clientId         String
  dogId            String?
  type             EnrollmentType   @default(FULL)
  status           EnrollmentStatus @default(ENROLLED)
  waitlistPosition Int? // set only while WAITLISTED
  // For DROP_IN: the 1-based session index they joined at, so pricing
  // and the roster only count sessions from here on.
  joinedAtIndex    Int?
  source           String           @default("TRAINER") // "TRAINER" | "SELF_SERVE"
  // Mirrors ClientPackage.invoicedAt — manual until billing is wired.
  invoicedAt       DateTime?
  enrolledAt       DateTime         @default(now())
  withdrawnAt      DateTime?

  classRun    ClassRun            @relation(fields: [classRunId], references: [id], onDelete: Cascade)
  client      ClientProfile       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dog         Dog?                @relation(fields: [dogId], references: [id], onDelete: SetNull)
  attendance  SessionAttendance[]
  paymentItem PaymentItem?

  @@unique([classRunId, clientId, dogId])
  @@index([classRunId])
  @@index([clientId])
  @@map("class_enrollments")
}

// Per-enrollee record for one shared class session: the roster grid AND
// the per-dog in-class note/scores. scores is a free JSON bag so the
// trainer can score whatever they like without a migration.
model SessionAttendance {
  id           String           @id @default(cuid())
  sessionId    String
  enrollmentId String
  status       AttendanceStatus @default(PRESENT)
  note         String?          @db.Text
  scores       Json             @default("{}")
  // This client's own filled report for the session (per "each client has its
  // own form"): { formId, answers: {qid:val}, images: {qid:[url]}, intro,
  // closing }. Null = not written yet.
  report       Json?
  // Draft vs sent for the report above. Null = saved draft, not yet visible to
  // the client; set = recap sent (client notified + visible).
  reportSentAt DateTime?
  markedAt     DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  session    TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollment ClassEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, enrollmentId])
  @@index([sessionId])
  @@index([enrollmentId])
  @@map("session_attendance")
}

// ─── General scheduling waitlist ──────────────────────────────────────────────
// Trainer-wide list of people the trainer wants to take on but has no
// availability for yet. Distinct from the per-ClassRun waitlist (which
// means a specific cohort is full). The subject can be an existing client
// OR a prospect (contact snapshot, like an unlinked Enquiry).

enum WaitlistStatus {
  WAITING
  CONTACTED // trainer has reached out, not yet booked
  SCHEDULED // converted into a booking
  REMOVED // no longer waiting (declined / went elsewhere)
}

model WaitlistEntry {
  id                 String         @id @default(cuid())
  trainerId          String
  // Optional link to an existing client. When null this is a prospect —
  // name is always set; email/phone are the contact snapshot.
  clientId           String?
  name               String
  email              String?
  phone              String?
  // What they want. packageId = a specific package of interest (optional);
  // request = freeform ("6-week reactive course, weekday evenings").
  packageId          String?
  request            String?        @db.Text
  sessionType        SessionType?
  // Time preferences for matching to openings. preferredDays holds
  // ISO weekday numbers (1=Mon … 7=Sun); empty = any day. The time
  // window mirrors AvailabilitySlot's "HH:MM" 24-hr strings.
  preferredDays      Int[]          @default([])
  preferredTimeStart String? // "HH:MM" or null = any
  preferredTimeEnd   String? // "HH:MM" or null = any
  earliestStart      DateTime?      @db.Date
  notes              String?        @db.Text
  // Manual ordering — lower = higher priority (top of the list).
  priority           Int            @default(0)
  status             WaitlistStatus @default(WAITING)
  contactedAt        DateTime?
  convertedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  client  ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  package Package?       @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([trainerId, status])
  @@index([clientId])
  @@index([packageId])
  @@map("waitlist_entries")
}

// ─── Client self-booking ──────────────────────────────────────────────────────
// A client self-booked a package from their availability tab. For
// approval-required packages this row is PENDING until the trainer
// confirms (then it spawns a ClientPackage + sessions). Instant-book
// packages skip this model entirely and create the booking directly.

enum BookingRequestStatus {
  PENDING
  CONFIRMED
  DECLINED
}

model BookingRequest {
  id                       String               @id @default(cuid())
  trainerId                String
  clientId                 String
  packageId                String
  dogId                    String?
  // Proposed session datetimes (ISO strings), generated from the
  // client's chosen start on the package cadence. The trainer can
  // adjust on the calendar after confirming.
  sessionDates             Json                 @default("[]")
  status                   BookingRequestStatus @default(PENDING)
  // The booking page this request came from (soft ref), so confirming it can
  // stamp the resulting sessions with the page for BEFORE/AFTER automations.
  bookingPageId            String?
  note                     String?              @db.Text
  // Set on confirm — links to the created assignment for traceability.
  resultingClientPackageId String?
  createdAt                DateTime             @default(now())
  decidedAt                DateTime?

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  client  ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  package Package        @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([trainerId, status])
  @@index([clientId])
  @@map("booking_requests")
}

// ─── Trainer gamification ─────────────────────────────────────────────────────
// Engagement streak for trainers (distinct from the client-facing
// Achievement system). One row per trainer per ISO week in which they
// did a qualifying "meaningful work action". The streak is consecutive
// active weeks, derived from these rows. Badge catalogue lives in code
// (lib/trainer-streak.ts, like NOTIFICATION_TYPES); only awards persist.

model TrainerActivityWeek {
  id              String   @id @default(cuid())
  trainerId       String
  // ISO week key, e.g. "2026-W20" (lexically sortable within a year;
  // streak math uses a parsed week index, not string order).
  isoWeek         String
  firstActivityAt DateTime @default(now())

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([trainerId, isoWeek])
  @@index([trainerId])
  @@map("trainer_activity_weeks")
}

model TrainerBadgeAward {
  id        String   @id @default(cuid())
  trainerId String
  // Stable key from the in-code badge catalogue (e.g. "streak_4w",
  // "clients_10", "sessions_50").
  badgeKey  String
  awardedAt DateTime @default(now())

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([trainerId, badgeKey])
  @@index([trainerId])
  @@map("trainer_badge_awards")
}

// ─── Session report forms ─────────────────────────────────────────────────────

// Trainer-defined questionnaire that can be attached to any TrainingSession to
// capture a structured report. Questions live as a JSON array so the trainer
// can reorder/add/remove without schema migrations:
//   [{ id, label, type: 'SHORT_TEXT'|'LONG_TEXT'|'NUMBER'|'RATING_1_5', required }]
model SessionForm {
  id              String  @id @default(cuid())
  trainerId       String
  isSample        Boolean @default(false)
  name            String
  description     String? @db.Text
  introText       String? @db.Text // shown above the questions during fill + on the report
  closingText     String? @db.Text // shown below the questions during fill + on the report
  // Visual treatment for the client-facing report. backgroundUrl wins over
  // backgroundColor when both are set.
  backgroundColor String? // hex/CSS colour, e.g. "#fef3c7"
  backgroundUrl   String? // public image URL, applied as a tiled cover
  questions       Json    @default("[]")
  order           Int     @default(0)
  // When false the form is a draft — hidden from the trainer's session-form
  // picker. New defaults seeded by the onboarding init helper start as drafts
  // so trainers review them before they're usable in real sessions.
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer            TrainerProfile        @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  responses          SessionFormResponse[]
  defaultForPackages Package[]             @relation("PackageDefaultSessionForm")

  @@index([trainerId])
  @@map("session_forms")
}

// One trainer-filled response per (session, form). A session can have many
// responses (multiple forms attached). `answers` is a JSON object keyed by
// question id → string (we store everything as text; rendering interprets it).
model SessionFormResponse {
  id               String  @id @default(cuid())
  sessionId        String
  formId           String
  answers          Json    @default("{}")
  // Per-question image lists, keyed by question id → string[] of URLs
  imagesByQuestion Json    @default("{}")
  // Trainer-authored top/bottom messages for the report. Optional and
  // independent of the form template's introText/closingText (which act as
  // suggested defaults the trainer can copy in).
  introMessage     String? @db.Text
  closingMessage   String? @db.Text

  // Draft vs sent. Null = the trainer has saved a draft the client cannot see
  // yet. Set = the recap has been sent (client notified + visible). Saving a
  // note leaves this null; the explicit "send" action stamps it.
  sentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  form    SessionForm     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([sessionId, formId])
  @@index([sessionId])
  @@index([formId])
  @@map("session_form_responses")
}

// ─── Training Templates ───────────────────────────────────────────────────────

model TrainingTemplate {
  id          String  @id @default(cuid())
  trainerId   String
  name        String
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  tasks   TemplateTask[]

  @@map("training_templates")
}

model TemplateTask {
  id          String  @id @default(cuid())
  templateId  String
  dayOffset   Int // day 1, 2, 3... from program start
  title       String
  description String? @db.Text
  repetitions Int?
  videoUrl    String?
  order       Int     @default(0)

  template TrainingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_tasks")
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model Message {
  id                  String         @id @default(cuid())
  channel             MessageChannel
  clientId            String // the client this message thread relates to
  senderId            String
  body                String         @db.Text
  // Sanitized HTML body for messages composed in the rich-text editor (e.g. an
  // emailed announcement logged to the thread). Null = plain `body` only.
  bodyHtml            String?        @db.Text
  readAt              DateTime?
  // Set once the deferred-email fallback has been sent (or deliberately skipped)
  // for this message, so the message-email-fallback cron never double-emails.
  emailFallbackSentAt DateTime?

  createdAt DateTime @default(now())

  client ClientProfile @relation("ClientMessages", fields: [clientId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id])

  @@index([clientId])
  @@index([senderId])
  @@index([createdAt])
  // Hot path for the fallback cron: unread, un-emailed messages by age.
  @@index([channel, readAt, emailFallbackSentAt, createdAt])
  @@map("messages")
}

// ─── Notifications ────────────────────────────────────────────────────────────

// Dedup log for client session reminders — one row per (session, client, lead)
// so the cron never resends the same reminder.
model ClientReminderSent {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  leadMinutes Int
  sentAt      DateTime @default(now())

  @@unique([sessionId, userId, leadMinutes])
  @@index([sessionId])
  @@map("client_reminders_sent")
}

model Notification {
  id        String            @id @default(cuid())
  userId    String
  title     String
  body      String
  // Optional category + deep link so the feed can group/route. Null = legacy.
  type      NotificationType?
  link      String?
  readAt    DateTime?
  createdAt DateTime          @default(now())

  @@index([userId])
  @@map("notifications")
}

// ─── Custom Client Fields ─────────────────────────────────────────────────────

model CustomField {
  id         String          @id @default(cuid())
  trainerId  String
  isSample   Boolean         @default(false)
  label      String
  type       CustomFieldType
  required   Boolean         @default(false)
  // Whether this field appears in (and is required for) the quick-add contact
  // form. `required` above governs the full create form / intake.
  inQuickAdd Boolean         @default(false)
  options    Json? // string[] for DROPDOWN
  order      Int             @default(0)
  category   String? // optional grouping label
  appliesTo  String          @default("OWNER") // "OWNER" | "DOG"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile     @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  values  CustomFieldValue[]

  @@index([trainerId])
  @@map("custom_fields")
}

model CustomFieldValue {
  id       String  @id @default(cuid())
  fieldId  String
  clientId String
  dogId    String? // set when field appliesTo = "DOG"
  value    String  @db.Text

  updatedAt DateTime @updatedAt

  field  CustomField   @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  client ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([fieldId, clientId, dogId])
  @@map("custom_field_values")
}

// ─── Subscription Plans ───────────────────────────────────────────────────────

model SubscriptionPlan {
  id                           String  @id @default(cuid())
  name                         String
  description                  String? @db.Text
  priceMonthly                 Float
  maxClients                   Int? // null = unlimited
  featureFlags                 Json    @default("{}")
  isActive                     Boolean @default(true)
  // Stripe Price ID this plan maps to (e.g. price_1Abc…). Null while a
  // plan exists in our DB but hasn't been wired to Stripe yet — the
  // checkout flow filters those out so the trainer can't pick a plan
  // we can't actually charge for. Treated as the NZD default; per-
  // currency overrides live in stripePriceIdsByCurrency.
  stripePriceId                String? @unique
  // Per-currency Stripe Price IDs. Shape: { "AUD": "price_…", "USD": "price_…" }.
  // The /billing/setup page lets the trainer pick a currency; we look
  // up the matching price here at Checkout time. If the chosen
  // currency has no entry, we fall back to stripePriceId (NZD) and
  // surface that to the trainer in the UI.
  stripePriceIdsByCurrency     Json    @default("{}")
  // Stripe TEST-mode price IDs (sandbox), mirroring the live columns above.
  // Sandbox trainers (e.g. the demo) resolve against these instead.
  stripePriceIdTest            String?
  stripePriceIdsByCurrencyTest Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainers TrainerProfile[]

  @@map("subscription_plans")
}

// ─── Billing Items (seats + add-ons) ──────────────────────────────────────────
// The Core software base lives in SubscriptionPlan (id "core"). Everything
// that stacks on top of it — the per-seat "extra trainer" charge and the
// toggleable add-ons — is a BillingItem. Each carries the same Stripe price
// shape as SubscriptionPlan (NZD default in `stripePriceId`, per-currency
// overrides in `stripePriceIdsByCurrency`) so the price-resolution logic in
// lib/billing.ts is shared. Prices mirror src/lib/pricing.ts / the marketing
// site — the website is the source of truth.

enum BillingItemKind {
  SEAT
  ADDON
}

model BillingItem {
  // Stable string ids matching src/lib/pricing.ts: "seat", "achievements",
  // "shop", "ai". Used as the join key on TrainerAddon and the lookup key
  // when building Checkout line items.
  id                           String          @id
  kind                         BillingItemKind
  name                         String
  description                  String?         @db.Text
  // NZD reference price — display/sanity only; Stripe is authoritative.
  priceMonthly                 Float
  // Canonical (NZD) Stripe Price ID; per-currency overrides below. Null
  // until wired to Stripe. Same semantics as SubscriptionPlan.
  stripePriceId                String?         @unique
  // Shape: { "AUD": "price_…", "USD": "price_…" }. Falls back to
  // stripePriceId (NZD) when a currency has no entry.
  stripePriceIdsByCurrency     Json            @default("{}")
  // Stripe TEST-mode price IDs (sandbox), mirroring the live columns above.
  stripePriceIdTest            String?
  stripePriceIdsByCurrencyTest Json            @default("{}")
  isActive                     Boolean         @default(true)
  // Display order in the /billing/setup add-on list.
  sortOrder                    Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainerAddons TrainerAddon[]

  @@map("billing_items")
}

// One row per (trainer, add-on) the trainer has switched on. The seat
// charge is NOT tracked here — it's a quantity on TrainerProfile.seatCount.
// stripeSubscriptionItemId lets us target the exact line item later for
// pro-rata add/remove ("toggle any add-on anytime", phase 2).
model TrainerAddon {
  id                       String  @id @default(cuid())
  trainerId                String
  itemId                   String // BillingItem.id, kind = ADDON
  // Stripe subscription item id for this add-on's line. Null until the
  // webhook reconciles the subscription after checkout.
  stripeSubscriptionItemId String? @unique
  // False = toggled off but row kept for history. The active set drives
  // feature gating + billing.
  active                   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  item    BillingItem    @relation(fields: [itemId], references: [id])

  @@unique([trainerId, itemId])
  @@index([trainerId])
  @@map("trainer_addons")
}

// ─── Client→Trainer payments (Flow B, Stripe Connect Express) ─────────────────
// A Payment is one hosted-Checkout charge a client made to a trainer, settled on
// the platform account as a *destination charge* (transfer_data.destination =
// the trainer's Connect account, application_fee_amount = our platform cut).
// Stripe handles the split + payout; we just record the result and fulfil what
// was bought. PaymentItem rows link a payment to the things it created
// (ClientPackage / TrainingSession / Product / ClassEnrollment). This is wholly
// separate from the trainer's own subscription to PupManager.

enum PaymentStatus {
  PENDING // Checkout session created, not yet paid
  PAID // payment_intent succeeded
  FAILED
  REFUNDED // fully refunded
  PARTIALLY_REFUNDED
  DISPUTED // chargeback opened
  CANCELLED // session expired / abandoned
}

enum PurchasableKind {
  PACKAGE // → ClientPackage created/activated
  SESSION // → single TrainingSession (booking-page slot)
  PRODUCT // → Product purchase
  CLASS_ENROLLMENT // → ClassEnrollment (group / drop-in)
}

model Payment {
  id        String  @id @default(cuid())
  trainerId String
  // ClientProfile.id — null for a prospect paying before conversion.
  clientId  String?

  // Stripe identifiers. The Checkout Session/PaymentIntent live on the platform
  // account; the resulting charge sits on the connected account.
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique
  stripeChargeId          String?
  // Denormalised acct_… that received the funds (survives trainer edits).
  connectAccountId        String

  // Money in minor units. amountTotal = what the client paid.
  amountTotal          Int
  currency             String // ISO 4217 lower-case, matches payoutCurrency at sale time
  applicationFeeAmount Int // our platform fee, minor units
  // Stripe's processing ("credit card") fee for this charge, minor units. Read
  // from the charge's balance_transaction on payment success and shown on the
  // invoice/earnings breakdown (gross − card fee − platform fee = net). Null
  // until the webhook fills it in.
  stripeFeeAmount      Int?
  amountRefunded       Int           @default(0)
  status               PaymentStatus @default(PENDING)
  // Which Stripe mode this lived in (mirrors TrainerProfile.sandboxBilling at
  // sale time) so webhooks/refunds reach for the right key pair.
  sandbox              Boolean       @default(false)
  // Human description of what was bought, denormalised for the earnings list so
  // deleting a Package/Product never orphans payment history.
  description          String?

  createdAt DateTime  @default(now())
  paidAt    DateTime?
  updatedAt DateTime  @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  client  ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items   PaymentItem[]
  refunds Refund[]

  @@index([trainerId, status])
  @@index([clientId])
  @@map("payments")
}

model PaymentItem {
  id          String          @id @default(cuid())
  paymentId   String
  kind        PurchasableKind
  // Snapshot of name + unit price at sale time (history survives edits/deletes).
  description String
  unitAmount  Int
  quantity    Int             @default(1)

  // Links to the fulfilled rows, set on payment success. One-to-one for the
  // session/package/enrollment a payment created; product can repeat across
  // payments so it's a plain FK.
  clientPackageId   String? @unique
  trainingSessionId String? @unique
  productId         String?
  classEnrollmentId String? @unique
  // What to create on payment success, captured at checkout time, e.g.
  // { packageId, slotIso, dogId, bookingPageId, quantity }.
  intent            Json?

  payment         Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  clientPackage   ClientPackage?   @relation(fields: [clientPackageId], references: [id], onDelete: SetNull)
  trainingSession TrainingSession? @relation(fields: [trainingSessionId], references: [id], onDelete: SetNull)
  product         Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  classEnrollment ClassEnrollment? @relation(fields: [classEnrollmentId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@map("payment_items")
}

model Refund {
  id             String   @id @default(cuid())
  paymentId      String
  stripeRefundId String   @unique
  amount         Int // minor units
  reason         String? // trainer note or Stripe reason
  status         String // "pending" | "succeeded" | "failed"
  createdAt      DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("refunds")
}

// ─── Training Library ─────────────────────────────────────────────────────────

model LibraryType {
  id        String   @id @default(cuid())
  trainerId String
  isSample  Boolean  @default(false)
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  themes  LibraryTheme[]

  @@index([trainerId])
  @@map("library_types")
}

model LibraryTheme {
  id        String   @id @default(cuid())
  typeId    String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type  LibraryType   @relation(fields: [typeId], references: [id], onDelete: Cascade)
  tasks LibraryTask[]

  @@index([typeId])
  @@map("library_themes")
}

model LibraryTask {
  id          String   @id @default(cuid())
  themeId     String
  title       String
  description String?  @db.Text
  repetitions Int?
  videoUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  theme LibraryTheme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@index([themeId])
  @@map("library_tasks")
}

// ─── Client Notifications ─────────────────────────────────────────────────────

model ClientNotification {
  id        String   @id @default(cuid())
  clientId  String
  trainerId String
  subject   String
  notes     String?  @db.Text
  sentAt    DateTime @default(now())

  client  ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_notifications")
