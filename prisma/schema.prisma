generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  TRAINER
  CLIENT
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIALING
  CANCELLED
}

enum ShareType {
  READ_ONLY
  CO_MANAGE
  TRANSFER
}

enum SessionType {
  IN_PERSON
  VIRTUAL
}

enum SessionStatus {
  UPCOMING
  COMPLETED
  COMMENTED
  INVOICED
}

enum MessageChannel {
  TRAINER_CLIENT   // visible to client
  TRAINER_TRAINER  // private between trainers
}

enum CustomFieldType {
  TEXT
  NUMBER
  DROPDOWN
}

enum ProductKind {
  PHYSICAL
  DIGITAL
}

enum ProductRequestStatus {
  PENDING    // client wants this, hasn't been delivered yet
  FULFILLED  // trainer marked it delivered (linked to a session)
  CANCELLED  // client withdrew the request, or trainer dismissed it
}

// ─── Core User ───────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          Role
  emailVerified DateTime?
  image         String?
  timezone      String    @default("Pacific/Auckland")

  notifyEmail Boolean @default(true)
  notifyPush  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth
  accounts Account[]
  sessions Session[]

  // Role-specific profiles
  trainerProfile TrainerProfile?
  clientProfile  ClientProfile?

  // Messages sent by this user
  sentMessages Message[]

  @@map("users")
}

// ─── NextAuth Models ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Trainer Profile ─────────────────────────────────────────────────────────

model TrainerProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  businessName    String
  phone           String?
  logoUrl         String?
  dashboardBgUrl  String? // background image shown on the client home dashboard
  inviteTemplate  String? @db.Text // customisable invite email template

  // Google Calendar integration
  googleCalendarRefreshToken String? @db.Text
  googleCalendarConnected    Boolean @default(false)

  // Schedule view preferences — controls the visible hour range and which
  // weekdays render in the week grid. Days are 1=Mon..7=Sun.
  scheduleStartHour Int  @default(7)   // inclusive
  scheduleEndHour   Int  @default(21)  // exclusive (last hour shown is end-1)
  scheduleDays      Json @default("[1,2,3,4,5,6,7]")
  // Up to 2 extra fields rendered on schedule blocks. Allowed ids:
  // "location" | "description" | "sessionType" | "duration" | "title"
  scheduleExtraFields Json @default("[]")
  // Trainer-chosen visible columns on /clients. Allowed ids:
  // "email" | "dog" | "breed" | "extraDogs" | "nextSession" | "compliance" | "shared" | "custom:<id>"
  clientListColumns Json @default("[\"email\",\"dog\",\"nextSession\",\"compliance\"]")
  // Grouping for /clients. null = flat list. "nextDay" = group by day of
  // next booking. "custom:<id>" = group by custom-field value.
  clientListGroupBy String?

  // Subscription
  subscriptionPlanId String?
  subscriptionStatus SubscriptionStatus @default(TRIALING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan  SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  clients           ClientProfile[]
  sharedClients     ClientShare[]     @relation("SharedByTrainer")
  receivedClients   ClientShare[]     @relation("SharedWithTrainer")
  trainingSessions  TrainingSession[]
  trainingTemplates TrainingTemplate[]
  customFields       CustomField[]
  libraryTypes       LibraryType[]
  embedForms         EmbedForm[]
  sentNotifications  ClientNotification[]
  availabilitySlots  AvailabilitySlot[]
  blackoutPeriods    BlackoutPeriod[]
  packages           Package[]
  sessionForms       SessionForm[]
  products           Product[]
  achievements       Achievement[]

  @@map("trainer_profiles")
}

// ─── Client & Dog ────────────────────────────────────────────────────────────

model ClientProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  trainerId String  // primary trainer
  dogId     String? // set after onboarding
  status    String  @default("ACTIVE") // "ACTIVE" | "INACTIVE"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainer TrainerProfile @relation(fields: [trainerId], references: [id])
  dog     Dog?           @relation("PrimaryDog", fields: [dogId], references: [id])

  diaryEntries      TrainingTask[]
  trainingSessions  TrainingSession[]
  shares            ClientShare[]
  messages          Message[]          @relation("ClientMessages")
  customFieldValues CustomFieldValue[]
  dogs              Dog[]              @relation("AdditionalDogs")
  notifications     ClientNotification[]
  clientPackages    ClientPackage[]
  productRequests   ProductRequest[]
  buddySessions     SessionBuddy[]
  achievements      ClientAchievement[]

  @@index([trainerId])
  @@map("client_profiles")
}

model Dog {
  id              String    @id @default(cuid())
  name            String
  breed           String?
  weight          Float?    // kg
  dob             DateTime?
  photoUrl        String?
  notes           String?   @db.Text
  clientProfileId String?   // owner (for additional dogs in a household)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  primaryFor ClientProfile[]  @relation("PrimaryDog")
  owner      ClientProfile?   @relation("AdditionalDogs", fields: [clientProfileId], references: [id])
  sessions   TrainingSession[]
  tasks      TrainingTask[]
  buddySessions SessionBuddy[]

  @@index([clientProfileId])
  @@map("dogs")
}

// ─── Client Sharing ───────────────────────────────────────────────────────────

model ClientShare {
  id           String    @id @default(cuid())
  clientId     String
  sharedById   String
  sharedWithId String
  shareType    ShareType
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())

  client     ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sharedBy   TrainerProfile @relation("SharedByTrainer", fields: [sharedById], references: [id])
  sharedWith TrainerProfile @relation("SharedWithTrainer", fields: [sharedWithId], references: [id])

  @@index([clientId])
  @@index([sharedWithId])
  @@map("client_shares")
}

// ─── Training Diary & Tasks ───────────────────────────────────────────────────

model TrainingTask {
  id          String   @id @default(cuid())
  clientId    String
  dogId       String?  // optional: which dog this task is for
  sessionId   String?  // optional: linked training session
  date        DateTime @db.Date
  title       String
  description String?  @db.Text
  repetitions Int?
  videoUrl    String?  // trainer-provided instructional link
  trainerNote String?  @db.Text   // per-task comment from the trainer
  imageUrls   Json     @default("[]") // string[] of public image URLs
  order       Int      @default(0) // display order within a session

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     ClientProfile   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dog        Dog?            @relation(fields: [dogId], references: [id])
  session    TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  completion TaskCompletion?

  @@index([clientId])
  @@index([date])
  @@index([sessionId])
  @@map("training_tasks")
}

model TaskCompletion {
  id          String   @id @default(cuid())
  taskId      String   @unique
  completedAt DateTime @default(now())
  note        String?  @db.Text
  videoUrl    String?  // client-submitted link
  videoS3Key  String?  // native video upload (S3)

  task TrainingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_completions")
}

// ─── Scheduling ──────────────────────────────────────────────────────────────

model TrainingSession {
  id          String      @id @default(cuid())
  trainerId   String
  clientId    String?     // direct client link (optional, in addition to dogId)
  dogId       String?
  clientPackageId String? // membership in an assigned package
  title       String
  description String?     @db.Text
  scheduledAt DateTime
  durationMins Int        @default(60)
  sessionType SessionType   @default(IN_PERSON)
  status      SessionStatus @default(UPCOMING)
  location    String?
  virtualLink String?

  googleCalendarEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  client  ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  dog     Dog?           @relation(fields: [dogId], references: [id])
  clientPackage ClientPackage? @relation(fields: [clientPackageId], references: [id], onDelete: SetNull)
  tasks   TrainingTask[]
  formResponses SessionFormResponse[]
  fulfilledProductRequests ProductRequest[]
  buddies SessionBuddy[]

  @@index([trainerId])
  @@index([clientId])
  @@index([scheduledAt])
  @@index([clientPackageId])
  @@map("training_sessions")
}

// "Buddy session" — additional client/dog pairs attending a TrainingSession
// alongside the primary client/dog. Trainer-only visibility (the buddy client's
// portal does not surface these). Same client may appear twice with two
// different dogs, so the unique key includes dogId.
model SessionBuddy {
  id        String   @id @default(cuid())
  sessionId String
  clientId  String
  dogId     String?
  createdAt DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  client  ClientProfile   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dog     Dog?            @relation(fields: [dogId], references: [id], onDelete: SetNull)

  @@unique([sessionId, clientId, dogId])
  @@index([sessionId])
  @@index([clientId])
  @@map("session_buddies")
}

// ─── Products (trainer shop) ─────────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  trainerId   String
  name        String
  description String?     @db.Text
  kind        ProductKind @default(PHYSICAL)
  // Price in cents to avoid float issues. Null = unpriced / "Contact trainer".
  priceCents  Int?
  imageUrl    String?
  // Required for DIGITAL products — the file the customer downloads. Public URL
  // (e.g. Vercel Blob) or signed URL handed out at access time.
  downloadUrl String?
  category    String?     // free-form trainer-defined grouping ("Treats", "Guides")
  featured    Boolean     @default(false) // surfaces on the client home dashboard
  active      Boolean     @default(true)  // hide from clients without deleting
  order       Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer  TrainerProfile   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  requests ProductRequest[]

  @@index([trainerId])
  @@index([category])
  @@map("products")
}

// A client's standing request for a product. Stays PENDING and rolls forward
// onto each successive upcoming session until the trainer marks it FULFILLED
// (typically because they handed the item over at a session) or CANCELLED.
model ProductRequest {
  id        String                @id @default(cuid())
  clientId  String
  productId String
  status    ProductRequestStatus  @default(PENDING)

  // Optional notes from the client when they request (e.g. "for Bella, size L")
  note String? @db.Text

  // Set when trainer fulfils the request — links it to the session where it
  // was delivered, for the trainer's own records.
  fulfilledSessionId String?
  fulfilledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client            ClientProfile   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  fulfilledSession  TrainingSession? @relation(fields: [fulfilledSessionId], references: [id], onDelete: SetNull)

  @@index([clientId, status])
  @@index([productId])
  @@map("product_requests")
}

// ─── Packages ─────────────────────────────────────────────────────────────────

model Package {
  id           String   @id @default(cuid())
  trainerId    String
  name         String
  description  String?  @db.Text
  sessionCount Int      @default(3)
  weeksBetween Int      @default(2)   // gap between sessions, in weeks
  durationMins Int      @default(60)  // default duration applied to created sessions
  sessionType  SessionType @default(IN_PERSON)
  // Prices in cents to avoid float precision issues. specialPriceCents is an
  // optional discounted price the trainer can offer for promotions, etc.
  priceCents        Int? // null = unpriced
  specialPriceCents Int? // null = no special price
  // Optional schedule colour (Tailwind palette key, eg "blue"). When set,
  // sessions assigned to this package render in that colour on the calendar.
  color        String?
  order        Int      @default(0)   // display order, lowest first

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer     TrainerProfile  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  assignments ClientPackage[]

  @@index([trainerId])
  @@map("packages")
}

model ClientPackage {
  id         String   @id @default(cuid())
  packageId  String
  clientId   String
  startDate  DateTime
  assignedAt DateTime @default(now())
  // When true, the schedule auto-creates more sessions on the package's
  // cadence so the calendar always has ~6 weeks of sessions ahead.
  extendIndefinitely Boolean @default(false)

  package  Package           @relation(fields: [packageId], references: [id], onDelete: Cascade)
  client   ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessions TrainingSession[]

  @@index([clientId])
  @@index([packageId])
  @@map("client_packages")
}

// ─── Session report forms ─────────────────────────────────────────────────────

// Trainer-defined questionnaire that can be attached to any TrainingSession to
// capture a structured report. Questions live as a JSON array so the trainer
// can reorder/add/remove without schema migrations:
//   [{ id, label, type: 'SHORT_TEXT'|'LONG_TEXT'|'NUMBER'|'RATING_1_5', required }]
model SessionForm {
  id          String   @id @default(cuid())
  trainerId   String
  name        String
  description String?  @db.Text
  introText   String?  @db.Text   // shown above the questions during fill + on the report
  closingText String?  @db.Text   // shown below the questions during fill + on the report
  // Visual treatment for the client-facing report. backgroundUrl wins over
  // backgroundColor when both are set.
  backgroundColor String? // hex/CSS colour, e.g. "#fef3c7"
  backgroundUrl   String? // public image URL, applied as a tiled cover
  questions   Json     @default("[]")
  order       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer   TrainerProfile        @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  responses SessionFormResponse[]

  @@index([trainerId])
  @@map("session_forms")
}

// One trainer-filled response per (session, form). A session can have many
// responses (multiple forms attached). `answers` is a JSON object keyed by
// question id → string (we store everything as text; rendering interprets it).
model SessionFormResponse {
  id        String   @id @default(cuid())
  sessionId String
  formId    String
  answers   Json     @default("{}")
  // Per-question image lists, keyed by question id → string[] of URLs
  imagesByQuestion Json @default("{}")
  // Trainer-authored top/bottom messages for the report. Optional and
  // independent of the form template's introText/closingText (which act as
  // suggested defaults the trainer can copy in).
  introMessage   String? @db.Text
  closingMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  form    SessionForm     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([sessionId, formId])
  @@index([sessionId])
  @@index([formId])
  @@map("session_form_responses")
}

// ─── Training Templates ───────────────────────────────────────────────────────

model TrainingTemplate {
  id          String  @id @default(cuid())
  trainerId   String
  name        String
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  tasks   TemplateTask[]

  @@map("training_templates")
}

model TemplateTask {
  id          String  @id @default(cuid())
  templateId  String
  dayOffset   Int     // day 1, 2, 3... from program start
  title       String
  description String? @db.Text
  repetitions Int?
  videoUrl    String?
  order       Int     @default(0)

  template TrainingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_tasks")
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model Message {
  id        String         @id @default(cuid())
  channel   MessageChannel
  clientId  String         // the client this message thread relates to
  senderId  String
  body      String         @db.Text
  readAt    DateTime?

  createdAt DateTime @default(now())

  client ClientProfile @relation("ClientMessages", fields: [clientId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id])

  @@index([clientId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ─── Custom Client Fields ─────────────────────────────────────────────────────

model CustomField {
  id        String          @id @default(cuid())
  trainerId String
  label     String
  type      CustomFieldType
  required  Boolean         @default(false)
  options   Json?           // string[] for DROPDOWN
  order     Int             @default(0)
  category  String?         // optional grouping label
  appliesTo String          @default("OWNER") // "OWNER" | "DOG"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile     @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  values  CustomFieldValue[]

  @@index([trainerId])
  @@map("custom_fields")
}

model CustomFieldValue {
  id       String  @id @default(cuid())
  fieldId  String
  clientId String
  dogId    String? // set when field appliesTo = "DOG"
  value    String  @db.Text

  updatedAt DateTime @updatedAt

  field  CustomField   @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  client ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([fieldId, clientId, dogId])
  @@map("custom_field_values")
}

// ─── Subscription Plans ───────────────────────────────────────────────────────

model SubscriptionPlan {
  id              String  @id @default(cuid())
  name            String
  description     String? @db.Text
  priceMonthly    Float
  maxClients      Int?    // null = unlimited
  featureFlags    Json    @default("{}")
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainers TrainerProfile[]

  @@map("subscription_plans")
}

// ─── Training Library ─────────────────────────────────────────────────────────

model LibraryType {
  id        String   @id @default(cuid())
  trainerId String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  themes  LibraryTheme[]

  @@index([trainerId])
  @@map("library_types")
}

model LibraryTheme {
  id        String   @id @default(cuid())
  typeId    String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type  LibraryType   @relation(fields: [typeId], references: [id], onDelete: Cascade)
  tasks LibraryTask[]

  @@index([typeId])
  @@map("library_themes")
}

model LibraryTask {
  id          String   @id @default(cuid())
  themeId     String
  title       String
  description String?  @db.Text
  repetitions Int?
  videoUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  theme LibraryTheme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@index([themeId])
  @@map("library_tasks")
}

// ─── Client Notifications ─────────────────────────────────────────────────────

model ClientNotification {
  id        String   @id @default(cuid())
  clientId  String
  trainerId String
  subject   String
  notes     String?  @db.Text
  sentAt    DateTime @default(now())

  client  ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_notifications")
}

// ─── Trainer Availability ─────────────────────────────────────────────────────

model AvailabilitySlot {
  id          String    @id @default(cuid())
  trainerId   String
  title       String?
  dayOfWeek   Int?      // 1=Mon … 7=Sun; null = one-off date
  date        DateTime? @db.Date
  startTime   String    // "HH:MM" 24-hr
  endTime     String    // "HH:MM" 24-hr
  // 1 = weekly, 2 = fortnightly, etc. Only used when dayOfWeek is set.
  cadenceWeeks Int      @default(1)
  // Anchor date for cadence > 1 — defines parity (e.g. which fortnight is "on").
  firstDate    DateTime? @db.Date
  createdAt   DateTime  @default(now())

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@map("availability_slots")
}

// Trainer holiday / blackout periods. Days that fall inside one of these
// ranges count as unavailable, regardless of weekly slots.
model BlackoutPeriod {
  id        String   @id @default(cuid())
  trainerId String
  reason    String?
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@map("blackout_periods")
}

// ─── Trainer-defined Achievements ────────────────────────────────────────────

enum AchievementTrigger {
  MANUAL
  FIRST_SESSION
  SESSIONS_COMPLETED
  IN_PERSON_SESSIONS
  VIRTUAL_SESSIONS
  CONSECUTIVE_SESSIONS_ATTENDED
  FIRST_PACKAGE_ASSIGNED
  PACKAGES_COMPLETED
  FIRST_HOMEWORK_DONE
  HOMEWORK_TASKS_DONE
  HOMEWORK_STREAK_DAYS
  PERFECT_WEEK
  CLIENT_ANNIVERSARY_DAYS
  MESSAGES_SENT
  PRODUCTS_PURCHASED
  PROFILE_COMPLETED
}

// Trainer-curated catalogue of achievements / badges. Each row is *either* a
// MANUAL achievement (trainer awards from the client profile) *or* an automatic
// rule with a trigger type and threshold (system awards via evaluateAchievementsFor).
model Achievement {
  id          String   @id @default(cuid())
  trainerId   String
  name        String
  description String?  @db.Text
  icon        String?
  color       String?
  order       Int      @default(0)
  // Auto-award rule. MANUAL = no auto-award; the rest are evaluated by the
  // awarder helper when relevant counters change. triggerValue is the integer
  // threshold (eg 5 for "5 sessions"); null for binary triggers.
  triggerType  AchievementTrigger @default(MANUAL)
  triggerValue Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trainer TrainerProfile      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  awards  ClientAchievement[]

  @@index([trainerId])
  @@map("achievements")
}

// Per-client award log. Unique on (clientId, achievementId) so the awarder is
// idempotent — re-evaluating a client never double-awards. earnedValue captures
// the snapshot counter at award time so the UI can render "5 sessions".
model ClientAchievement {
  id            String   @id @default(cuid())
  clientId      String
  achievementId String
  awardedAt     DateTime @default(now())
  // "system" for automatic awards, the trainer's userId for manual awards.
  awardedBy     String
  earnedValue   Int?

  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  achievement Achievement   @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([clientId, achievementId])
  @@index([clientId])
  @@map("client_achievements")
}

// ─── Embed Forms ──────────────────────────────────────────────────────────────

model EmbedForm {
  id              String   @id @default(cuid())
  trainerId       String
  title           String
  description     String?  @db.Text
  // JSON array of { key: string, required: boolean } for standard fields
  // Keys: phone | dogName | dogBreed | dogWeight | dogDob | message
  fields          Json     @default("[]")
  // JSON string[] of CustomField ids to include
  customFieldIds  Json     @default("[]")
  thankYouMessage String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@map("embed_forms")
}
