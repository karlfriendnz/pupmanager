// ─── Trainer Availability ─────────────────────────────────────────────────────

model AvailabilitySlot {
  id           String    @id @default(cuid())
  trainerId    String
  isSample     Boolean   @default(false)
  title        String?
  dayOfWeek    Int? // 1=Mon … 7=Sun; null = one-off date
  date         DateTime? @db.Date
  startTime    String // "HH:MM" 24-hr
  endTime      String // "HH:MM" 24-hr
  // 1 = weekly, 2 = fortnightly, etc. Only used when dayOfWeek is set.
  cadenceWeeks Int       @default(1)
  // Anchor date for cadence > 1 — defines parity (e.g. which fortnight is "on").
  firstDate    DateTime? @db.Date
  createdAt    DateTime  @default(now())

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@map("availability_slots")
}

// Trainer holiday / blackout periods. Days that fall inside one of these
// ranges count as unavailable, regardless of weekly slots.
model BlackoutPeriod {
  id        String   @id @default(cuid())
  trainerId String
  reason    String?
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@map("blackout_periods")
}

// Calendly-style public booking page. One config row per trainer, exposed at
// /c/<slug>/book. Discrete bookable time-slots are derived at request time
// from the trainer's AvailabilitySlots minus blackouts and existing sessions,
// sliced by slotLengthMins/slotIntervalMins. A pick by an existing client runs
// the self-book engine (instant or BookingRequest per requiresApproval); a pick
// by a public prospect creates an Enquiry the trainer accepts (the accept both
// converts them to a client and books the chosen slot). Optionally tied to a
// package, in which case the chosen slot is session 1 and the rest auto-place
// on the package cadence; with no package each pick books a single session.
model BookingPage {
  id               String      @id @default(cuid())
  trainerId        String
  // URL segment under /c/<trainerSlug>/book/<slug>. Unique per trainer. A
  // trainer can run several pages (e.g. "intro-call", "puppy-class") each with
  // their own package, slot rules and approval setting.
  slug             String
  // Internal label (also the default public headline if none set).
  name             String      @default("Book a session")
  order            Int         @default(0)
  enabled          Boolean     @default(false)
  headline         String?
  intro            String?     @db.Text
  // Trainer-set slot granularity. slotLengthMins is the session length each
  // slot represents; slotIntervalMins is the step between consecutive slot
  // starts (e.g. 60-min slots every 30 min produces overlapping start times).
  slotLengthMins   Int         @default(60)
  slotIntervalMins Int         @default(60)
  // Per-link instant-vs-approval choice for booking by an existing client.
  // (Prospects always route through Enquiry accept, which is itself approval.)
  requiresApproval Boolean     @default(true)
  // Pay-to-confirm: when true an existing client must pay before the slot is
  // booked (the connect webhook materialises it on success). Payment supersedes
  // requiresApproval. The price is the package's (when packageId is set) or
  // priceCents for a single-session page. Prospects still route via Enquiry.
  requiresPayment  Boolean     @default(false)
  // Single-session price (minor units) when the page has no package. Ignored
  // for package pages — those charge the package's own price.
  priceCents       Int?
  // Earliest a slot may be booked, in hours from now — stops same-minute books.
  minNoticeHours   Int         @default(12)
  // How far ahead slots are offered.
  windowDays       Int         @default(28)
  // Per-page availability window. When availStartTime + availEndTime are both
  // set, the page generates slots directly from these (availDays + the daily
  // window) instead of the trainer's global schedule availability. Times are
  // "HH:MM" 24h; availDays is ISO weekdays (1=Mon..7=Sun).
  availDays        Json        @default("[1,2,3,4,5]")
  availStartTime   String?
  availEndTime     String?
  // Optional package the booking kicks off. Null = single one-off session of
  // slotLengthMins. SetNull so deleting the package just reverts to single.
  packageId        String?
  sessionType      SessionType @default(IN_PERSON)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer     TrainerProfile      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  package     Package?            @relation(fields: [packageId], references: [id], onDelete: SetNull)
  automations BookingAutomation[]
  sessions    TrainingSession[]

  @@unique([trainerId, slug])
  @@index([trainerId])
  @@index([packageId])
  @@map("booking_pages")
}

// When an automation fires relative to a booking.
enum BookingAutomationTrigger {
  ON_BOOKING // immediately when the slot is booked / requested
  BEFORE_SESSION // offsetMinutes before the session start
  AFTER_SESSION // offsetMinutes after the session start
}

// A trainer-authored email that fires automatically off a booking-page booking.
// ON_BOOKING sends inline at booking time; BEFORE/AFTER_SESSION are picked up by
// the booking-automations cron once their offset relative to the session is due.
// Subject/body are plain text with {name} {dog} {time} {business} placeholders.
model BookingAutomation {
  id            String                   @id @default(cuid())
  bookingPageId String
  trigger       BookingAutomationTrigger
  // Minutes relative to the session start for BEFORE/AFTER. Ignored for ON_BOOKING.
  offsetMinutes Int                      @default(1440)
  enabled       Boolean                  @default(true)
  subject       String
  body          String                   @db.Text
  order         Int                      @default(0)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  bookingPage BookingPage             @relation(fields: [bookingPageId], references: [id], onDelete: Cascade)
  sends       BookingAutomationSend[]

  @@index([bookingPageId])
  @@map("booking_automations")
}

// One row per (automation, session) already sent — dedups the time-based cron
// so a reminder/follow-up goes out exactly once even if ticks overlap.
model BookingAutomationSend {
  id           String   @id @default(cuid())
  automationId String
  sessionId    String
  sentAt       DateTime @default(now())

  automation BookingAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  session    TrainingSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([automationId, sessionId])
  @@index([sessionId])
  @@map("booking_automation_sends")
}

// ─── Trainer-defined Achievements ────────────────────────────────────────────

enum AchievementTrigger {
  MANUAL
  FIRST_SESSION
  SESSIONS_COMPLETED
  IN_PERSON_SESSIONS
  VIRTUAL_SESSIONS
  CONSECUTIVE_SESSIONS_ATTENDED
  FIRST_PACKAGE_ASSIGNED
  PACKAGES_COMPLETED
  FIRST_HOMEWORK_DONE
  HOMEWORK_TASKS_DONE
  HOMEWORK_STREAK_DAYS
  PERFECT_WEEK
  CLIENT_ANNIVERSARY_DAYS
  MESSAGES_SENT
  PRODUCTS_PURCHASED
  PROFILE_COMPLETED
}

// Trainer-curated catalogue of achievements / badges. Each row is *either* a
// MANUAL achievement (trainer awards from the client profile) *or* an automatic
// rule with a trigger type and threshold (system awards via evaluateAchievementsFor).
model Achievement {
  id           String             @id @default(cuid())
  trainerId    String
  isSample     Boolean            @default(false)
  name         String
  description  String?            @db.Text
  icon         String?
  color        String?
  order        Int                @default(0)
  // When false the achievement is hidden from clients and not auto-awarded.
  // Trainers use this to draft new achievements before surfacing them or to
  // pause an existing one without deleting it.
  published    Boolean            @default(true)
  // Auto-award rule. MANUAL = no auto-award; the rest are evaluated by the
  // awarder helper when relevant counters change. triggerValue is the integer
  // threshold (eg 5 for "5 sessions"); null for binary triggers.
  triggerType  AchievementTrigger @default(MANUAL)
  triggerValue Int?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  trainer TrainerProfile      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  awards  ClientAchievement[]

  @@index([trainerId])
  @@map("achievements")
}

// Per-client award log. Unique on (clientId, achievementId) so the awarder is
// idempotent — re-evaluating a client never double-awards. earnedValue captures
// the snapshot counter at award time so the UI can render "5 sessions".
model ClientAchievement {
  id            String   @id @default(cuid())
  clientId      String
  achievementId String
  awardedAt     DateTime @default(now())
  // "system" for automatic awards, the trainer's userId for manual awards.
  awardedBy     String
  earnedValue   Int?

  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  achievement Achievement   @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([clientId, achievementId])
  @@index([clientId])
  @@map("client_achievements")
}

// ─── Embed Forms ──────────────────────────────────────────────────────────────

model EmbedForm {
  id                     String   @id @default(cuid())
  trainerId              String
  isSample               Boolean  @default(false)
  title                  String
  description            String?  @db.Text
  // JSON array of { key: string, required: boolean } for standard fields
  // Keys: phone | dogName | dogBreed | dogWeight | dogDob | message
  fields                 Json     @default("[]")
  // JSON string[] of CustomField ids to include
  customFieldIds         Json     @default("[]")
  thankYouTitle          String?  @db.Text
  thankYouMessage        String?  @db.Text
  isActive               Boolean  @default(true)
  // Styling — let trainers match the form to their site's brand.
  // showBorder draws the slate-200 card border around field groups;
  // off for embeds where the parent page already provides framing.
  // buttonColor is a hex string (e.g. "#2563eb") for the submit
  // button; null falls back to the platform blue.
  showBorder             Boolean  @default(true)
  buttonColor            String?
  // Welcome email — sent by acceptEnquiry when a trainer accepts an
  // enquiry from this form and opts into the magic-link invite. All
  // null/default values fall back to the platform copy in
  // src/lib/enquiries.ts. Subject + intro support {business} and
  // {name} placeholders. welcomeShowDiaryButton hides the magic-link
  // CTA (and its label) for trainers who'd rather send a plain
  // welcome; the greeting, branding, and expiry note stay templated.
  welcomeSubject         String?  @db.Text
  welcomeIntro           String?  @db.Text
  welcomeShowDiaryButton Boolean  @default(true)
  welcomeButtonLabel     String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  enquiries Enquiry[]

  @@index([trainerId])
  @@map("embed_forms")
}

// ─── Lead magnets (free download → mailing list) ──────────────────────────────
// A trainer-owned freebie: a downloadable file behind a branded public form.
// A prospect submits name + email (+ consent) and is emailed the download link
// and added to the trainer's mailing list (Subscriber). Gated by the
// 'leadmagnets' add-on. Public URL: /c/<trainerSlug>/free/<slug>.
model LeadMagnet {
  id              String   @id @default(cuid())
  trainerId       String
  slug            String // per-trainer unique, used in the public URL
  title           String
  description     String?  @db.Text
  // Landing-page copy (fall back to title/description when null).
  headline        String?  @db.Text
  intro           String?  @db.Text
  // Which landing-page layout the trainer picked: classic | split | spotlight | minimal.
  layout          String   @default("classic")
  // Optional hero image (public Blob URL) shown on the photo-based layouts.
  imageUrl        String?
  // The download itself — a public Vercel Blob URL (same model as digital
  // products). fileName/size are shown in the UI and the delivery email.
  fileUrl         String
  fileName        String
  fileSizeBytes   Int?
  // Consent copy shown beside the required checkbox. Platform-standard (not
  // trainer-editable); snapshotted onto each Subscriber for an audit trail.
  consentText     String   @default("I agree to receive emails and accept the privacy policy.") @db.Text
  // Trainer-customisable delivery email. Null falls back to the default copy
  // in lead-magnet-email.ts.
  emailSubject    String?  @db.Text
  emailIntro      String?  @db.Text
  thankYouTitle   String?  @db.Text
  thankYouMessage String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trainer     TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  subscribers Subscriber[]

  @@unique([trainerId, slug])
  @@index([trainerId])
  @@map("lead_magnets")
}

enum SubscriberStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
}

// A marketing subscriber on a trainer's single mailing list — an email-only
// lead captured via a lead magnet, decoupled from ClientProfile. The Marketing
// add-on can broadcast to SUBSCRIBED rows. sourceLeadMagnet is SetNull so
// deleting a magnet leaves its captured leads intact.
model Subscriber {
  id                 String           @id @default(cuid())
  trainerId          String
  email              String
  name               String?
  status             SubscriberStatus @default(SUBSCRIBED)
  sourceLeadMagnetId String?
  // Snapshot of the consent text + when they ticked it (compliance trail).
  consentText        String?          @db.Text
  consentAt          DateTime?
  unsubscribedAt     DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  trainer          TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  sourceLeadMagnet LeadMagnet?    @relation(fields: [sourceLeadMagnetId], references: [id], onDelete: SetNull)

  @@unique([trainerId, email])
  @@index([trainerId, status])
  @@map("subscribers")
}

// ─── Enquiries (lead funnel) ──────────────────────────────────────────────────
// Form submissions land here in NEW state. Trainer can Reply, then Accept
// (creates User + ClientProfile + Dog + magic-link email) or Decline.
// Form values are snapshotted as columns + JSON so an enquiry stays readable
// even if the embed form's field config changes later.

model Enquiry {
  id        String  @id @default(cuid())
  trainerId String
  isSample  Boolean @default(false)
  formId    String? // null if the source form was deleted

  // Snapshot of form values at submit time
  name              String
  email             String
  phone             String?
  dogName           String?
  dogBreed          String?
  dogWeight         Float?
  dogDob            DateTime?
  message           String?   @db.Text
  // { customFieldId: value } map of custom-field answers, snapshotted
  customFieldValues Json      @default("{}")

  status                EnquiryStatus @default(NEW)
  // Set when the trainer first opens the enquiry — drives the dashboard badge.
  viewedAt              DateTime?
  // Highest follow-up nudge already sent for this unanswered enquiry:
  // 0 = none, 1 = 6h, 2 = 18h, 3 = 24h, 4 = 36h. The enquiry-followups cron
  // bumps this as each threshold passes; reset is unnecessary because a reply
  // or status change takes the enquiry out of the cron's "unanswered" query.
  followupReminderLevel Int           @default(0)
  // Populated after Accept; gives a forward link to the resulting client.
  clientProfileId       String?       @unique

  // Set when the enquiry came from the public Calendly-style booking page:
  // the prospect's chosen slot (UTC instant) and the package they picked
  // (if the booking page offers one). On Accept these materialise into a
  // TrainingSession / package series so converting the prospect to a client
  // also books their session. bookedPackageId is a soft reference (no FK) —
  // it's re-validated against the trainer's packages at accept time.
  // bookedPageId points at the originating BookingPage (soft ref) so a
  // single-session booking can recover its duration / session type on accept.
  bookedSlotAt    DateTime?
  bookedPackageId String?
  bookedPageId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer       TrainerProfile   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  form          EmbedForm?       @relation(fields: [formId], references: [id], onDelete: SetNull)
  clientProfile ClientProfile?   @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  messages      EnquiryMessage[]

  @@index([trainerId, status])
  @@index([trainerId, createdAt])
  @@map("enquiries")
}

enum EnquiryStatus {
  NEW
  ACCEPTED
  DECLINED
  ARCHIVED
}

// Outbound replies the trainer sent to the enquirer. v1 is one-way (no
// inbound threading) so direction is implicit-outbound; we still keep the
// column to make v2 (Gmail/Microsoft OAuth, two-way) a non-breaking change.
model EnquiryMessage {
  id           String   @id @default(cuid())
  enquiryId    String
  direction    String   @default("OUTBOUND") // "OUTBOUND" | "INBOUND"
  subject      String
  bodyText     String   @db.Text
  // Rich-text (sanitized HTML) version of the body composed in the editor.
  // Null for legacy/plain or inbound messages; bodyText stays the plain fallback.
  bodyHtml     String?  @db.Text
  // Trainer (User) who composed and sent this. Null if system-generated.
  sentByUserId String?
  createdAt    DateTime @default(now())

  enquiry Enquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  @@index([enquiryId, createdAt])
  @@map("enquiry_messages")
}

// ─── Onboarding ──────────────────────────────────────────────────────────────

// Admin-editable wizard step content. The trainer-facing wizard reads
// `publishedAt IS NOT NULL` rows ordered by `order`. Per-trainer state lives
// in TrainerOnboardingStepProgress, joined by `key` (no FK so admins can
// rename keys without cascading through trainer history).
model OnboardingStep {
  id          String    @id @default(cuid())
  key         String    @unique
  order       Int       @default(0)
  title       String
  body        String    @db.Text
  ctaLabel    String
  ctaHref     String
  skippable   Boolean   @default(true)
  skipWarning String?   @db.Text
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_steps")
}

// Admin-editable email template + send rule. The cron sender evaluates each
// published row's triggerRule against trainer state and dispatches via Resend.
// `senderKey` selects the founder voice ("karl" | "brooke") for from-address
// and signature.
model OnboardingEmail {
  id           String    @id @default(cuid())
  key          String    @unique
  subject      String
  body         String    @db.Text
  // Optional intro text shown ABOVE the hero image.
  topText      String?   @db.Text
  // Optional hero image shown in the email (admin-uploaded, public Blob URL).
  imageUrl     String?
  // Optional fixed display height for the image in px (null = natural/auto).
  imageHeight  Int?
  // Optional click-through link for the first image (wraps it in an <a href>).
  linkUrl      String?
  // Optional SECOND image block, shown below the body (admin-uploaded Blob URL).
  imageUrl2    String?
  imageHeight2 Int?
  // Optional click-through link for the second image.
  linkUrl2     String?
  // Optional THIRD text block, shown below the second image.
  bottomText   String?   @db.Text
  // Manual position within the admin "series" list (lower = earlier). Send
  // timing is still driven by triggerRule; this only controls list order.
  sortOrder    Int       @default(0)
  senderKey    String    @default("karl")
  // Examples:
  //   { "type": "on_signup" }
  //   { "type": "after_signup", "hours": 24, "requireStepIncomplete": "business_profile" }
  //   { "type": "after_first_invite_sent", "hours": 24, "requireNoClientSignedIn": true }
  //   { "type": "on_aha_reached" }
  triggerRule  Json
  publishedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_emails")
}

// Trainer-owned, reusable email templates the trainer composes from when
// emailing clients (e.g. from the Messages composer). The body is sanitized
// rich-text HTML authored in the editor; subject/body support {{placeholders}}
// the composer resolves per recipient (e.g. {{clientName}}, {{trainerName}},
// {{businessName}}, {{dogName}}). `category` is an optional grouping label.
model EmailTemplate {
  id        String  @id @default(cuid())
  trainerId String
  name      String
  category  String?
  subject   String  @db.Text
  body      String  @db.Text
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId, sortOrder])
  @@map("email_templates")
}

// One row per bulk email a trainer sends to a selection of their clients from
// the Clients-list composer. `subject`/`body` are the authored template (before
// per-recipient {{placeholder}} substitution). Recipients (one row each) hang
// off it for delivery tracking and to power the per-trainer daily send cap.
model EmailBroadcast {
  id             String @id @default(cuid())
  trainerId      String
  // The User (owner/staff) who composed and sent it.
  senderId       String
  subject        String @db.Text
  body           String @db.Text
  recipientCount Int    @default(0)

  createdAt DateTime @default(now())

  trainer    TrainerProfile            @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  recipients EmailBroadcastRecipient[]

  @@index([trainerId, createdAt])
  @@map("email_broadcasts")
}

// One row per recipient of a broadcast. `resendEmailId` is the id Resend returns
// for the sent message, used to map inbound delivery/open/click/bounce webhook
// events back to the row. `clientProfileId` is nullable so a later client delete
// doesn't orphan the send record.
model EmailBroadcastRecipient {
  id              String    @id @default(cuid())
  broadcastId     String
  clientProfileId String?
  email           String
  // Resend message id (from batch.send), unique so the webhook can upsert by it.
  resendEmailId   String?   @unique
  // SENT | DELIVERED | OPENED | CLICKED | BOUNCED | COMPLAINED | FAILED
  status          String    @default("SENT")
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  complainedAt    DateTime?

  createdAt DateTime @default(now())

  broadcast EmailBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@map("email_broadcast_recipients")
}

// One row per trainer, created on first dashboard load. ahaReachedAt fires
// when this trainer's first non-sample client signs in for the first time.
model TrainerOnboardingProgress {
  id                   String    @id @default(cuid())
  trainerId            String    @unique
  startedAt            DateTime  @default(now())
  ahaReachedAt         DateTime?
  // Timestamp of the trainer's first sent client invite — anchors the
  // chase-sequence drips (emails 3 and 4).
  firstInviteSentAt    DateTime?
  // Trainer dismissed the dashboard checklist widget independently of completion.
  checklistDismissedAt DateTime?
  // Set on the row when it was created via post-deploy backfill (trainer
  // existed before onboarding shipped). Suppresses auto-modal — instead the
  // dashboard shows a one-time opt-in banner. Null = fresh signup.
  backfilledAt         DateTime?
  // Set when the trainer dismissed the first-visit welcome modal — either by
  // clicking "Start the quick setup" or "Skip". Once set, the welcome never
  // shows again (the wizard / checklist take over).
  welcomeShownAt       DateTime?
  // Set ONLY when the trainer explicitly opts into the tour — either by
  // clicking "Start the quick setup" on the welcome modal or "Take the
  // tour" on the backfill banner. Skip / No thanks do NOT set this.
  // Gates the floating onboarding FAB and the pulsing menu/in-page dots
  // — those are tour-only nudges, so before opt-in nothing should fire.
  tourStartedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer TrainerProfile                  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  steps   TrainerOnboardingStepProgress[]
  emails  TrainerOnboardingEmailLog[]

  @@map("trainer_onboarding_progress")
}

// Per-trainer per-step state. `stepKey` is denormalised — no FK to
// OnboardingStep so admins can rename/delete steps without orphaning trainers.
model TrainerOnboardingStepProgress {
  id          String    @id @default(cuid())
  progressId  String
  stepKey     String
  startedAt   DateTime?
  completedAt DateTime?
  skippedAt   DateTime?

  progress TrainerOnboardingProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([progressId, stepKey])
  @@index([progressId])
  @@map("trainer_onboarding_step_progress")
}

// Idempotency log — `@@unique([progressId, emailKey])` prevents the cron
// sender from resending the same drip to the same trainer.
model TrainerOnboardingEmailLog {
  id         String   @id @default(cuid())
  progressId String
  emailKey   String
  sentAt     DateTime @default(now())

  progress TrainerOnboardingProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([progressId, emailKey])
  @@index([progressId])
  @@map("trainer_onboarding_email_logs")
}

// ─── Rate limiting ─────────────────────────────────────────────────────────
// Fixed-window counters for abuse control on sensitive/unauthenticated
// endpoints (login, register, password reset, public form submit). One row per
// rate-limit key (e.g. "login:1.2.3.4"); updated via an atomic upsert in
// src/lib/rate-limit.ts. resetAt marks when the window rolls over. Stale rows
// are harmless (overwritten on next hit for that key); the index supports an
// optional periodic prune.
model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
  @@map("rate_limits")
}

// Append-only audit trail for sensitive actions. Written ONLY by the trusted
// server helper recordAudit() (src/lib/audit.ts); the app never updates or
// deletes rows, and reads are gated to the owning company's OWNER or a platform
// ADMIN. Deliberately has NO foreign keys — ids are stored as plain strings so
// the trail survives deletion of the user/company it describes (forensics).
// meta must NEVER contain secrets, tokens, reset links, OTPs, or passwords.
enum AuditAction {
  USER_SIGNUP
  USER_LOGIN
  USER_LOGIN_FAILED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  EMAIL_CHANGED
  ROLE_CHANGED
  PERMISSIONS_CHANGED
  INVITE_CREATED
  INVITE_ACCEPTED
  MEMBER_REMOVED
  BILLING_CHANGED
  PAYMENTS_TOGGLED
  DATA_EXPORTED
  ACCOUNT_DELETION_REQUESTED
  ACCOUNT_DELETED
  ADMIN_ACTION
}

model AuditLog {
  id          String      @id @default(cuid())
  // The business this event belongs to, for scoping reads. Null for pre-tenant
  // events (signup, failed login before a company is resolved).
  companyId   String?
  // Who performed it (User.id). Null for anonymous / failed-auth events.
  actorUserId String?
  action      AuditAction
  // What it acted on — free-form ("membership", "user", "payment") + its id.
  targetType  String?
  targetId    String?
  ip          String?
  userAgent   String?
  // Extra structured, non-sensitive context.
  meta        Json?
  createdAt   DateTime    @default(now())

  @@index([companyId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

// ─── Dashboard scratchpad: Brain dump + To-dos ────────────────────────────────
// Per-trainer dashboard right-rail. The brain dump is a single freeform note per
// (company, user) that autosaves. To-dos are shared across the company and can
// be assigned to a team member when the org has more than one trainer.

// One freeform note per (company, user). Autosaves (debounced) from the
// dashboard panel; scoped to the logged-in user so each trainer has their own.
model TrainerBrainDump {
  id        String   @id @default(cuid())
  companyId String // → TrainerProfile.id (the business / tenant)
  userId    String // → User.id (whose brain dump this is)
  body      String   @default("") @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company TrainerProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@map("trainer_brain_dumps")
}

// A shared company to-do. Created by a trainer; optionally assigned to a team
// member (TrainerMembership) when the org has more than one trainer. assignedTo
// is SetNull so removing a member leaves their to-dos intact but unassigned.
model TrainerTodo {
  id           String    @id @default(cuid())
  companyId    String // → TrainerProfile.id (the business / tenant)
  title        String
  done         Boolean   @default(false)
  createdById  String // → User.id (who created it)
  assignedToId String? // → TrainerMembership.id (who it's assigned to)
  dueDate      DateTime?
  sortOrder    Int       @default(0)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company    TrainerProfile     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User               @relation("TodoCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  assignedTo TrainerMembership? @relation("TodoAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@map("trainer_todos")
}
