# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pupmanager"

# NextAuth
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Resend (email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@pupmanager.com"

# AWS S3 (video uploads)
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="pupmanager-videos"

# Google OAuth — powers both Sign in with Google AND the per-trainer Google
# Calendar sync add-on. Create an OAuth 2.0 "Web application" client in Google
# Cloud Console, enable the Google Calendar API, and add the redirect URI
# {NEXT_PUBLIC_APP_URL}/api/google-calendar/callback (locally:
# http://localhost:7777/api/google-calendar/callback). Optional — when unset,
# the Connect Google Calendar card shows a "not configured" state.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Maps Platform — route manager + address autocomplete. Two separate keys
# from the same Google Cloud project:
#   - GOOGLE_MAPS_SERVER_KEY: server-side only (Directions/Routes API). Restrict
#     by IP or leave unrestricted-but-secret. Never exposed to the browser.
#   - NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY: shipped to the browser (Maps
#     JavaScript API + Places). Restrict by HTTP referrer.
# Enable the Maps JavaScript API, Places API and Routes/Directions API, or every
# call 403s. NEXT_PUBLIC_* is inlined at compile time, so a key added while the
# dev server is running never reaches the browser until you restart `npm run dev`
# — that, not a missing key, is the usual cause of "maps key missing in the page".
# Put it in .env.local.
GOOGLE_MAPS_SERVER_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=""

# Xero accounting integration (OAuth2). Create a Custom Connection / Web app at
# https://developer.xero.com → set the redirect URI to
# {NEXT_PUBLIC_APP_URL}/api/xero/callback. Optional — when unset, the Connect
# Xero card shows a "not configured" state.
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""

# Cron security
CRON_SECRET="replace-with-random-secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (billing). Optional — until set, /billing/plans falls back to a
# "billing coming soon" state and the trial banner has no CTA.
STRIPE_SECRET_KEY=""
# Webhook signing secret from Stripe Dashboard → Webhooks → endpoint signing
# secret. Required for /api/webhooks/stripe to verify event integrity.
STRIPE_WEBHOOK_SECRET=""

# Stripe Connect (client→trainer payments). Signing secret for the SEPARATE
# Connect webhook endpoint (/api/webhooks/stripe/connect). Optional until Flow B
# ships — onboarding/checkout stay off while unset.
STRIPE_CONNECT_WEBHOOK_SECRET=""
# Platform fee on client→trainer payments, in basis points (500 = 5%).
PLATFORM_FEE_BPS="0"

# Xero webhook signing key (Xero app → Webhooks). Needed only for real-time inbound
# payment reconciliation; the poll cron + manual "Check Xero" button work without it.
XERO_WEBHOOK_KEY=
