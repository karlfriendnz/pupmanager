# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pupmanager"

# NextAuth
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Resend (email)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@pupmanager.app"

# AWS S3 (video uploads)
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="pupmanager-videos"

# Google Calendar OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cron security
CRON_SECRET="replace-with-random-secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
